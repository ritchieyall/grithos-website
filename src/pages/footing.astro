<script is:inline>
(function() {
  document.querySelectorAll('.situation-trigger').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var card = btn.closest('.situation-card');
      var answer = card.querySelector('.situation-answer');
      var isOpen = card.classList.contains('open');

      // Close all others
      document.querySelectorAll('.situation-card.open').forEach(function(openCard) {
        if (openCard !== card) {
          openCard.classList.remove('open');
          openCard.querySelector('.situation-trigger').setAttribute('aria-expanded', 'false');
          openCard.querySelector('.situation-answer').style.maxHeight = '0';
        }
      });

      if (isOpen) {
        card.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
        answer.style.maxHeight = '0';
      } else {
        card.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });
})();
</script>

