<script is:inline>
(function() {
  // ═══ ACCORDION ═══
  document.querySelectorAll('.situation-trigger').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var card = btn.closest('.situation-card');
      var answer = card.querySelector('.situation-answer');
      var isOpen = card.classList.contains('open');

      document.querySelectorAll('.situation-card.open').forEach(function(openCard) {
        if (openCard !== card) {
          openCard.classList.remove('open');
          openCard.querySelector('.situation-trigger').setAttribute('aria-expanded', 'false');
          openCard.querySelector('.situation-answer').style.maxHeight = '0';
        }
      });

      if (isOpen) {
        card.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
        answer.style.maxHeight = '0';
      } else {
        card.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });

  // ═══ SEARCH INDEX ═══
  var searchInput = document.getElementById('footingSearch');
  var suggestions = document.getElementById('searchSuggestions');
  var clearBtn = document.getElementById('searchClear');
  var resultCount = document.getElementById('resultCount');
  var sections = document.querySelectorAll('.footing-section[data-pillar]');
  var filterTabs = document.querySelectorAll('.filter-tab');
  var activeFilter = 'all';
  var highlightIdx = -1;

  // Build search index from all situation cards
  var searchIndex = [];
  sections.forEach(function(section) {
    var pillar = section.getAttribute('data-pillar');
    var pillarLabel = section.querySelector('.pillar-label').textContent;
    section.querySelectorAll('.situation-card').forEach(function(card) {
      var label = card.querySelector('.situation-label').textContent.replace(/[""]/g, '');
      var tenetTitle = card.querySelector('.workflow-step-title:nth-child(1)');
      var allText = [];
      card.querySelectorAll('.workflow-step-title, .workflow-step-body, .workflow-action').forEach(function(el) {
        allText.push(el.textContent);
      });
      var quote = card.querySelector('.workflow-quote');
      if (quote) allText.push(quote.textContent);

      // Extract rich keywords from content
      var keywords = allText.join(' ').toLowerCase();

      searchIndex.push({
        card: card,
        section: section,
        pillar: pillar,
        pillarLabel: pillarLabel,
        label: label,
        labelLower: label.toLowerCase(),
        keywords: keywords
      });
    });
  });

  function escapeHtml(str) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function highlightMatch(text, query) {
    if (!query) return escapeHtml(text);
    var escaped = escapeHtml(text);
    var re = new RegExp('(' + query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
    return escaped.replace(re, '<mark>$1</mark>');
  }

  function search(query) {
    var q = query.toLowerCase().trim();
    if (!q) return [];

    var words = q.split(/\s+/);

    var scored = searchIndex.map(function(item) {
      var score = 0;

      // Check if ALL words match somewhere
      var allMatch = words.every(function(w) {
        return item.labelLower.indexOf(w) !== -1 || item.keywords.indexOf(w) !== -1;
      });
      if (!allMatch) return null;

      // Score: prefer label matches over keyword matches
      words.forEach(function(w) {
        if (item.labelLower.indexOf(w) !== -1) score += 10;
        if (item.keywords.indexOf(w) !== -1) score += 3;
      });

      // Exact phrase match bonus
      if (item.labelLower.indexOf(q) !== -1) score += 20;

      // Filter by active pillar tab
      if (activeFilter !== 'all' && item.pillar !== activeFilter) return null;

      return { item: item, score: score };
    }).filter(Boolean);

    scored.sort(function(a, b) { return b.score - a.score; });
    return scored.map(function(s) { return s.item; });
  }

  function showSuggestions(results, query) {
    highlightIdx = -1;
    if (!query.trim()) {
      suggestions.classList.remove('open');
      suggestions.innerHTML = '';
      return;
    }

    if (results.length === 0) {
      suggestions.innerHTML = '<div class="search-no-results">No situations found. Try different words.</div>';
      suggestions.classList.add('open');
      return;
    }

    var html = '';
    results.slice(0, 8).forEach(function(item, i) {
      var pillarShort = item.pillar.charAt(0).toUpperCase() + item.pillar.slice(1);
      html += '<div class="suggestion-item" data-index="' + i + '">';
      html += '<span class="suggestion-pillar">' + pillarShort + '</span>';
      html += '<span class="suggestion-text">' + highlightMatch(item.label, query.trim()) + '</span>';
      html += '</div>';
    });
    suggestions.innerHTML = html;
    suggestions.classList.add('open');

    // Bind click handlers
    suggestions.querySelectorAll('.suggestion-item').forEach(function(el) {
      el.addEventListener('click', function() {
        var idx = parseInt(el.getAttribute('data-index'));
        selectResult(results[idx]);
      });
    });
  }

  function selectResult(item) {
    suggestions.classList.remove('open');
    searchInput.value = '';
    clearBtn.classList.remove('visible');
    resultCount.classList.remove('visible');

    // Reset filters
    resetFilters();

    // Close any open cards
    document.querySelectorAll('.situation-card.open').forEach(function(c) {
      c.classList.remove('open');
      c.querySelector('.situation-trigger').setAttribute('aria-expanded', 'false');
      c.querySelector('.situation-answer').style.maxHeight = '0';
    });

    // Scroll to card and open it
    var card = item.card;
    var yOffset = -120;
    var y = card.getBoundingClientRect().top + window.pageYOffset + yOffset;
    window.scrollTo({ top: y, behavior: 'smooth' });

    setTimeout(function() {
      card.classList.add('open');
      card.querySelector('.situation-trigger').setAttribute('aria-expanded', 'true');
      var answer = card.querySelector('.situation-answer');
      answer.style.maxHeight = answer.scrollHeight + 'px';

      // Brief gold highlight
      card.style.borderColor = 'var(--gold)';
      card.style.boxShadow = '0 0 0 3px rgba(196,168,130,.2)';
      setTimeout(function() {
        card.style.borderColor = '';
        card.style.boxShadow = '';
      }, 2000);
    }, 400);
  }

  function filterCards() {
    var query = searchInput.value.toLowerCase().trim();
    var visibleCount = 0;

    sections.forEach(function(section) {
      var pillar = section.getAttribute('data-pillar');
      var pillarHidden = activeFilter !== 'all' && pillar !== activeFilter;

      if (pillarHidden) {
        section.classList.add('hidden-section');
        return;
      }
      section.classList.remove('hidden-section');

      section.querySelectorAll('.situation-card').forEach(function(card) {
        if (!query) {
          card.classList.remove('hidden-card');
          visibleCount++;
          return;
        }

        var idx = searchIndex.findIndex(function(item) { return item.card === card; });
        if (idx === -1) return;
        var item = searchIndex[idx];
        var words = query.split(/\s+/);
        var match = words.every(function(w) {
          return item.labelLower.indexOf(w) !== -1 || item.keywords.indexOf(w) !== -1;
        });

        if (match) {
          card.classList.remove('hidden-card');
          visibleCount++;
        } else {
          card.classList.add('hidden-card');
        }
      });
    });

    if (query || activeFilter !== 'all') {
      resultCount.textContent = visibleCount + ' situation' + (visibleCount !== 1 ? 's' : '') + ' found';
      resultCount.classList.add('visible');
    } else {
      resultCount.classList.remove('visible');
    }
  }

  function resetFilters() {
    activeFilter = 'all';
    filterTabs.forEach(function(t) {
      t.classList.toggle('active', t.getAttribute('data-filter') === 'all');
    });
    sections.forEach(function(s) { s.classList.remove('hidden-section'); });
    document.querySelectorAll('.situation-card').forEach(function(c) { c.classList.remove('hidden-card'); });
    resultCount.classList.remove('visible');
  }

  // ═══ EVENT LISTENERS ═══
  var debounceTimer;
  searchInput.addEventListener('input', function() {
    var val = searchInput.value;
    clearBtn.classList.toggle('visible', val.length > 0);

    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(function() {
      var results = search(val);
      showSuggestions(results, val);
      filterCards();
    }, 150);
  });

  searchInput.addEventListener('focus', function() {
    var val = searchInput.value;
    if (val.trim()) {
      var results = search(val);
      showSuggestions(results, val);
    }
  });

  // Keyboard navigation
  searchInput.addEventListener('keydown', function(e) {
    var items = suggestions.querySelectorAll('.suggestion-item');
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      highlightIdx = Math.min(highlightIdx + 1, items.length - 1);
      items.forEach(function(el, i) { el.classList.toggle('highlighted', i === highlightIdx); });
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      highlightIdx = Math.max(highlightIdx - 1, 0);
      items.forEach(function(el, i) { el.classList.toggle('highlighted', i === highlightIdx); });
    } else if (e.key === 'Enter' && highlightIdx >= 0) {
      e.preventDefault();
      var idx = parseInt(items[highlightIdx].getAttribute('data-index'));
      var results = search(searchInput.value);
      if (results[idx]) selectResult(results[idx]);
    } else if (e.key === 'Escape') {
      suggestions.classList.remove('open');
      searchInput.blur();
    }
  });

  // Close suggestions on outside click
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.search-box')) {
      suggestions.classList.remove('open');
    }
  });

  clearBtn.addEventListener('click', function() {
    searchInput.value = '';
    clearBtn.classList.remove('visible');
    suggestions.classList.remove('open');
    suggestions.innerHTML = '';
    resetFilters();
    filterCards();
    searchInput.focus();
  });

  // ═══ FILTER TABS ═══
  filterTabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      activeFilter = tab.getAttribute('data-filter');
      filterTabs.forEach(function(t) { t.classList.remove('active'); });
      tab.classList.add('active');
      filterCards();

      // Re-run suggestions if search has text
      var val = searchInput.value;
      if (val.trim()) {
        var results = search(val);
        showSuggestions(results, val);
      }
    });
  });
})();
</script>

</BaseLayout>
