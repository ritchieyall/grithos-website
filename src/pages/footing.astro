---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Find Your Footing | Grithos"
  description="Life hit you with something? Find the pillar and tenet that speaks to where you are right now. Grithos meets you where you stand."
  ogTitle="Find Your Footing — Grithos"
  ogDescription="Map your moment to the philosophy. Whatever you're facing, there's a pillar, a tenet, and a practice for it."
  ogUrl="https://grithos.com/footing"
  canonical="https://grithos.com/footing"
  activePage="footing"
>

<style is:inline>
  /* ═══ PAGE HERO ═══ */
  .page-hero {
    padding: 160px 0 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .page-hero::before {
    content: '';
    position: absolute;
    top: 40%; left: 50%; transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(201,147,90,.05) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .page-hero .wrap { position: relative; z-index: 1; }
  .page-hero-overline {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }
  .page-hero-title {
    font-family: var(--heading);
    font-size: clamp(32px, 4.5vw, 52px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--white);
    margin-bottom: 16px;
  }
  .page-hero-sub {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(15px, 2vw, 18px);
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ═══ INTRO ═══ */
  .footing-intro {
    padding: 0 0 60px;
    text-align: center;
  }
  .footing-intro-text {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 17px;
    line-height: 1.9;
    color: var(--text-secondary);
    max-width: 680px;
    margin: 0 auto;
  }

  /* ═══ SITUATIONS GRID ═══ */
  .footing-section {
    padding: 0 0 80px;
  }
  .pillar-header {
    text-align: center;
    margin-bottom: 40px;
    padding-top: 60px;
    border-top: 1px solid var(--border);
  }
  .pillar-label {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
  }
  .pillar-name {
    font-family: var(--heading);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }
  .pillar-tagline {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 15px;
    font-style: italic;
    color: var(--text-muted);
  }

  .situation-grid {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .situation-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 28px 32px;
    cursor: pointer;
    transition: all .3s;
    position: relative;
    overflow: hidden;
  }
  .situation-card:hover {
    border-color: var(--gold-border);
    transform: translateY(-2px);
  }
  .situation-card.open {
    border-color: var(--gold-border);
  }

  .situation-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-align: left;
  }

  .situation-label {
    font-family: var(--heading);
    font-size: 17px;
    font-weight: 700;
    color: var(--white);
    line-height: 1.4;
    transition: color .2s;
  }
  .situation-card:hover .situation-label {
    color: var(--gold);
  }

  .situation-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .3s;
  }
  .situation-icon svg {
    width: 14px;
    height: 14px;
    color: var(--text-muted);
    transition: all .3s;
  }
  .situation-card.open .situation-icon {
    border-color: var(--gold);
    background: var(--gold-soft);
  }
  .situation-card.open .situation-icon svg {
    color: var(--gold);
    transform: rotate(45deg);
  }

  .situation-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height .4s cubic-bezier(.16,1,.3,1), opacity .3s;
    opacity: 0;
  }
  .situation-card.open .situation-answer {
    opacity: 1;
  }
  .situation-answer-inner {
    padding: 20px 0 4px;
  }

  /* ═══ WORKFLOW STEPS ═══ */
  .workflow {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .workflow-step {
    padding-left: 20px;
    border-left: 2px solid var(--border);
  }
  .workflow-step.active-step {
    border-left-color: var(--gold);
  }
  .workflow-step-label {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 6px;
  }
  .workflow-step-title {
    font-family: var(--heading);
    font-size: 14px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
  }
  .workflow-step-body {
    font-family: var(--body);
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .workflow-quote {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 14px;
    font-style: italic;
    color: var(--white);
    margin-bottom: 4px;
  }
  .workflow-cite {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: .05em;
  }
  .workflow-action {
    font-family: var(--heading);
    font-size: 14px;
    font-weight: 700;
    color: var(--white);
    line-height: 1.5;
  }
  .workflow-links {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 16px;
  }
  .workflow-link {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .05em;
    color: var(--gold);
    text-decoration: none;
    background: var(--gold-soft);
    border: 1px solid var(--gold-border);
    padding: 4px 12px;
    border-radius: 4px;
    transition: all .2s;
  }
  .workflow-link:hover {
    background: var(--gold-border);
    color: var(--white);
  }

  /* ═══ CLOSING ═══ */
  .closing {
    padding: 0 0 120px;
    text-align: center;
  }
  .closing-divider {
    width: 100%;
    height: 1px;
    background: var(--border);
    margin-bottom: 80px;
  }
  .closing-text {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(20px, 2.8vw, 28px);
    font-weight: 700;
    font-style: italic;
    color: var(--white);
    line-height: 1.5;
    max-width: 640px;
    margin: 0 auto 20px;
  }
  .closing-sub {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(15px, 2vw, 18px);
    font-style: italic;
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto 40px;
  }
  .back-link {
    font-family: var(--body);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: color .2s;
  }
  .back-link:hover { color: var(--gold); }
  .back-link svg { width: 14px; height: 14px; }

  @media(max-width: 768px) {
    .situation-card {
      padding: 22px 20px;
    }
    .situation-label {
      font-size: 15px;
    }
  }
</style>

<!-- HERO -->
<section class="page-hero">
  <div class="wrap">
    <p class="page-hero-overline reveal d1">Face It</p>
    <h1 class="page-hero-title reveal d2">Find Your Footing</h1>
    <p class="page-hero-sub reveal d3">Life hit you with something. Find the pillar and tenet that speaks to where you are right now.</p>
  </div>
</section>

<!-- INTRO -->
<section class="footing-intro">
  <div class="wrap">
    <p class="footing-intro-text reveal d4">You don't need to read the whole philosophy to start using it. Find the situation closest to yours. Grithos will meet you there.</p>
  </div>
</section>

<!-- ═══ PILLAR I — VIRTUE ═══ -->
<section class="footing-section">
  <div class="wrap">
    <div class="pillar-header reveal d1">
      <p class="pillar-label">Pillar I — Virtue</p>
      <h2 class="pillar-name">Do Right Regardless</h2>
      <p class="pillar-tagline">When the right thing is also the hard thing</p>
    </div>

    <div class="situation-grid">

      <div class="situation-card reveal d2">
        <button class="situation-trigger" aria-expanded="false">
          <span class="situation-label">"I lied and now it's eating me alive."</span>
          <span class="situation-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg></span>
        </button>
        <div class="situation-answer">
          <div class="situation-answer-inner">
            <div class="workflow">
              <div class="workflow-step active-step">
                <div class="workflow-step-label">The Pillar</div>
                <div class="workflow-step-title">Pillar I — Virtue: Do Right Regardless</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Tenet</div>
                <div class="workflow-step-title">Tenet I — Tell the Truth. Even When It Costs You.</div>
                <div class="workflow-step-body">The weight you feel is your ethos telling you it's wrong. The fallout from honesty is always lighter than the rot from silence.</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Lineage</div>
                <p class="workflow-quote">"If it is not right do not do it; if it is not true do not say it."</p>
                <div class="workflow-cite">— Marcus Aurelius, Meditations, Book XII</div>
              </div>
              <div class="workflow-step active-step">
                <div class="workflow-step-label">Your Practice</div>
                <p class="workflow-action">Tell the truth to the person you lied to. No preamble. No excuses. Just the truth.</p>
              </div>
            </div>
            <div class="workflow-links">
              <a href="/tenets#tenet-i" class="workflow-link">Read Tenet I →</a>
              <a href="/lineage" class="workflow-link">Read the Lineage →</a>
              <a href="/practice" class="workflow-link">Today's Practice →</a>
            </div>
          </div>
        </div>
      </div>

      <div class="situation-card reveal d3">
        <button class="situation-trigger" aria-expanded="false">
          <span class="situation-label">"I know what I should do, but it's going to cost me."</span>
          <span class="situation-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg></span>
        </button>
        <div class="situation-answer">
          <div class="situation-answer-inner">
            <div class="workflow">
              <div class="workflow-step active-step">
                <div class="workflow-step-label">The Pillar</div>
                <div class="workflow-step-title">Pillar I — Virtue: Do Right Regardless</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Tenet</div>
                <div class="workflow-step-title">Tenet I — Tell the Truth. Even When It Costs You.</div>
                <div class="workflow-step-body">If you already know it's right, the only thing stopping you is fear of what it costs. One of those you can recover from. The other follows you.</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Lineage</div>
                <p class="workflow-quote">"Waste no more time arguing about what a good man should be. Be one."</p>
                <div class="workflow-cite">— Marcus Aurelius, Meditations, Book X</div>
              </div>
              <div class="workflow-step active-step">
                <div class="workflow-step-label">Your Practice</div>
                <p class="workflow-action">Do the right thing. Accept the cost. You'll sleep tonight knowing who you are.</p>
              </div>
            </div>
            <div class="workflow-links">
              <a href="/tenets#tenet-i" class="workflow-link">Read Tenet I →</a>
              <a href="/lineage" class="workflow-link">Read the Lineage →</a>
              <a href="/practice" class="workflow-link">Today's Practice →</a>
            </div>
          </div>
        </div>
      </div>

      <div class="situation-card reveal d4">
        <button class="situation-trigger" aria-expanded="false">
          <span class="situation-label">"I made a promise I can't keep."</span>
          <span class="situation-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg></span>
        </button>
        <div class="situation-answer">
          <div class="situation-answer-inner">
            <div class="workflow">
              <div class="workflow-step active-step">
                <div class="workflow-step-label">The Pillar</div>
                <div class="workflow-step-title">Pillar I — Virtue: Do Right Regardless</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Tenet</div>
                <div class="workflow-step-title">Tenet II — Keep Your Word Like Your Life Depends on It.</div>
                <div class="workflow-step-body">Your word is only worth something if you protect it, even when it means admitting you overextended.</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Lineage</div>
                <p class="workflow-quote">"Never esteem anything as of advantage to you that will make you break your word or lose your self-respect."</p>
                <div class="workflow-cite">— Marcus Aurelius, Meditations, Book III</div>
              </div>
              <div class="workflow-step active-step">
                <div class="workflow-step-label">Your Practice</div>
                <p class="workflow-action">Call the person. Own it. Renegotiate or release them. But don't disappear.</p>
              </div>
            </div>
            <div class="workflow-links">
              <a href="/tenets#tenet-ii" class="workflow-link">Read Tenet II →</a>
              <a href="/lineage" class="workflow-link">Read the Lineage →</a>
              <a href="/practice" class="workflow-link">Today's Practice →</a>
            </div>
          </div>
        </div>
      </div>

      <div class="situation-card reveal d5">
        <button class="situation-trigger" aria-expanded="false">
          <span class="situation-label">"Something went wrong and it was my fault."</span>
          <span class="situation-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg></span>
        </button>
        <div class="situation-answer">
          <div class="situation-answer-inner">
            <div class="workflow">
              <div class="workflow-step active-step">
                <div class="workflow-step-label">The Pillar</div>
                <div class="workflow-step-title">Pillar I — Virtue: Do Right Regardless</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Tenet</div>
                <div class="workflow-step-title">Tenet III — Own Your Wins. But Do Right in the Dark.</div>
                <div class="workflow-step-body">Fix what can be fixed. Learn what can be learned. And move. Guilt without action is just self-pity dressed up as accountability.</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Lineage</div>
                <p class="workflow-quote">"He that is good for making excuses is seldom good for anything else."</p>
                <div class="workflow-cite">— Benjamin Franklin, Poor Richard's Almanack</div>
              </div>
              <div class="workflow-step active-step">
                <div class="workflow-step-label">Your Practice</div>
                <p class="workflow-action">Say it out loud to someone who was affected. "That was my fault. Here's what I'm doing about it."</p>
              </div>
            </div>
            <div class="workflow-links">
              <a href="/tenets#tenet-iii" class="workflow-link">Read Tenet III →</a>
              <a href="/lineage" class="workflow-link">Read the Lineage →</a>
              <a href="/practice" class="workflow-link">Today's Practice →</a>
            </div>
          </div>
        </div>
      </div>

      <div class="situation-card reveal d6">
        <button class="situation-trigger" aria-expanded="false">
          <span class="situation-label">"I'm going through a divorce and I feel like a failure."</span>
          <span class="situation-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg></span>
        </button>
        <div class="situation-answer">
          <div class="situation-answer-inner">
            <div class="workflow">
              <div class="workflow-step active-step">
                <div class="workflow-step-label">The Pillar</div>
                <div class="workflow-step-title">Pillar I — Virtue: Do Right Regardless</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Tenet</div>
                <div class="workflow-step-title">Tenet III — Own Your Wins. But Do Right in the Dark.</div>
                <div class="workflow-step-body">A marriage ending is not proof that you failed at life. It is proof that something broke. Own what was yours. Release what wasn't.</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Lineage</div>
                <p class="workflow-quote">"He that is good for making excuses is seldom good for anything else."</p>
                <div class="workflow-cite">— Benjamin Franklin, Poor Richard's Almanack</div>
              </div>
              <div class="workflow-step active-step">
                <div class="workflow-step-label">Your Practice</div>
                <p class="workflow-action">Write down what you could have done better. Not to punish yourself — to learn. Then write down what you did right. Carry the lessons. Leave the guilt.</p>
              </div>
            </div>
            <div class="workflow-links">
              <a href="/tenets#tenet-iii" class="workflow-link">Read Tenet III →</a>
              <a href="/lineage" class="workflow-link">Read the Lineage →</a>
              <a href="/practice" class="workflow-link">Today's Practice →</a>
            </div>
          </div>
        </div>
      </div>

      <div class="situation-card reveal d7">
        <button class="situation-trigger" aria-expanded="false">
          <span class="situation-label">"I feel like I'm failing as a parent."</span>
          <span class="situation-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg></span>
        </button>
        <div class="situation-answer">
          <div class="situation-answer-inner">
            <div class="workflow">
              <div class="workflow-step active-step">
                <div class="workflow-step-label">The Pillar</div>
                <div class="workflow-step-title">Pillar I — Virtue: Do Right Regardless</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Tenet</div>
                <div class="workflow-step-title">Tenet III — Own Your Wins. But Do Right in the Dark.</div>
                <div class="workflow-step-body">The fact that you're worried about failing means you care more than most. Perfection is not the standard. Presence is.</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Lineage</div>
                <p class="workflow-quote">"Well done is better than well said."</p>
                <div class="workflow-cite">— Benjamin Franklin, Poor Richard's Almanack</div>
              </div>
              <div class="workflow-step active-step">
                <div class="workflow-step-label">Your Practice</div>
                <p class="workflow-action">Write down three things you did for your children this week that no one saw. That is parenting. The doubt you feel is proof you care enough to question yourself.</p>
              </div>
            </div>
            <div class="workflow-links">
              <a href="/tenets#tenet-iii" class="workflow-link">Read Tenet III →</a>
              <a href="/lineage" class="workflow-link">Read the Lineage →</a>
              <a href="/practice" class="workflow-link">Today's Practice →</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══ PILLAR II — APEX ═══ -->
<section class="footing-section">
  <div class="wrap">
    <div class="pillar-header reveal d1">
      <p class="pillar-label">Pillar II — Apex</p>
      <h2 class="pillar-name">Own Your Nature</h2>
      <p class="pillar-tagline">When you need to become who you actually are</p>
    </div>

    <div class="situation-grid">

      <div class="situation-card reveal d2">
        <button class="situation-trigger" aria-expanded="false">
          <span class="situation-label">"I'm not living up to what I know I can be."</span>
          <span class="situation-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg></span>
        </button>
        <div class="situation-answer">
          <div class="situation-answer-inner">
            <div class="workflow">
              <div class="workflow-step active-step">
                <div class="workflow-step-label">The Pillar</div>
                <div class="workflow-step-title">Pillar II — Apex: Own Your Nature</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Tenet</div>
                <div class="workflow-step-title">Tenet IV — Never Shrink. Never Apologize for Strength.</div>
                <div class="workflow-step-body">You're dimming yourself to make someone else comfortable. That awareness is the starting line.</div>
              </div>
              <div class="workflow-step">
                <div class="workflow-step-label">The Lineage</div>
                <p class="workflow-quote">"First say to yourself what you would be; and then do what you have to do."</p>
                <div class="workflow-cite">— Epictetus, Discourses, Book III</div>
              </div>
              <div class="workflow-step active-step">
                <div class="workflow-step-label">Your Practice</div>
                <p class="workflow-action">Do the one thing you've been holding back on. Speak up. Step forward. Stop waiting for permission.</p>
              </div>
            </div>
            <div class="workflow-links">
              <a href="/tenets#tenet-iv" class="workflow-link">Read Tenet IV →</a>
