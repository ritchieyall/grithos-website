---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Merch | Grithos — The Four Pillars Collection"
  description="The Four Pillars Collection — T-shirts built on Virtue, Apex, Control, and Death. Do Right. Regardless. Wear it."
  ogTitle="Grithos Merch — The Four Pillars Collection"
  ogDescription="The Four Pillars Collection is live. Virtue. Apex. Control. Death. Do Right. Regardless. — Wear it."
  ogUrl="https://grithos.com/merch"
  canonical="https://grithos.com/merch"
  activePage="merch"
>

<style is:inline>
  /* ═══ MERCH HERO ═══ */
  .merch-hero {
    padding: 80px 0 28px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .merch-hero::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(196,168,130,.06) 0%, rgba(196,168,130,.02) 30%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .merch-hero .wrap {
    position: relative;
    z-index: 1;
  }
  .merch-overline {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }
  .merch-title {
    font-family: var(--heading);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 700;
    color: var(--white);
    letter-spacing: .02em;
    margin-bottom: 16px;
  }
  .merch-subtitle {
    font-family: var(--serif);
    font-size: clamp(16px, 2.2vw, 22px);
    font-style: italic;
    color: var(--text-secondary);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .merch-subtitle .gold { color: var(--gold); }

  /* ═══ COLLECTION LABEL ═══ */
  .collection-header {
    padding: 28px 0 12px;
    text-align: center;
  }

  /* ═══ PRODUCT GRID ═══ */
  .products {
    padding: 12px 0 40px;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  /* ═══ PRODUCT CARD ═══ */
  .product-card {
    background: linear-gradient(135deg, rgba(33,38,47,.9) 0%, rgba(28,32,41,.95) 100%);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: all .4s cubic-bezier(.16,1,.3,1);
    position: relative;
  }
  .product-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--gold) 50%, transparent 100%);
    opacity: 0;
    transition: opacity .4s;
  }
  .product-card:hover {
    border-color: var(--gold-border);
    box-shadow: 0 8px 60px rgba(196,168,130,.06), 0 0 1px rgba(196,168,130,.2);
    transform: translateY(-4px);
  }
  .product-card:hover::before {
    opacity: 0.8;
  }

  /* Placeholder image area */
  .product-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: linear-gradient(135deg, rgba(20,22,28,1) 0%, rgba(30,33,40,1) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    border-bottom: 1px solid var(--border);
  }
  .product-image-numeral {
    font-family: var(--heading);
    font-size: 80px;
    font-weight: 300;
    color: rgba(196,168,130,.08);
    line-height: 1;
    margin-bottom: 4px;
  }
  .product-image-name {
    font-family: var(--heading);
    font-size: 28px;
    font-weight: 700;
    color: rgba(196,168,130,.2);
    letter-spacing: .05em;
    text-transform: uppercase;
  }

  /* Badge */
  .product-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--void);
    background: var(--gold);
    padding: 4px 12px;
    border-radius: 4px;
  }

  /* Card body */
  .product-body {
    padding: 32px 28px;
    text-align: center;
  }
  .product-pillar-label {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .22em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .product-name {
    font-family: var(--heading);
    font-size: 28px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 12px;
  }
  .product-quote {
    font-family: var(--serif);
    font-size: 16px;
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 24px;
    max-width: 320px;
    margin-left: auto;
    margin-right: auto;
  }
  .product-btn {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--void);
    background: var(--gold);
    border: 1px solid var(--gold);
    padding: 12px 32px;
    border-radius: 6px;
    cursor: pointer;
    text-decoration: none;
    transition: all .3s;
  }
  .product-btn:hover {
    opacity: 0.85;
    box-shadow: 0 4px 20px rgba(196,168,130,.3);
    transform: translateY(-1px);
  }

  /* ═══ SHOP CTA BUTTON ═══ */
  .shop-cta-wrap {
    text-align: center;
    padding: 16px 0 40px;
  }
  .shop-cta-btn {
    display: inline-block;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--void);
    background: var(--gold);
    border: 2px solid var(--gold);
    padding: 18px 48px;
    border-radius: 8px;
    text-decoration: none;
    transition: all .3s;
  }
  .shop-cta-btn:hover {
    opacity: 0.85;
    box-shadow: 0 6px 30px rgba(196,168,130,.35);
    transform: translateY(-2px);
  }

  /* ═══ CTA SECTION ═══ */
  .merch-cta {
    padding: 28px 0 40px;
    text-align: center;
    position: relative;
  }
  .merch-cta::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 400px;
    background: radial-gradient(ellipse, rgba(196,168,130,.04) 0%, transparent 60%);
    pointer-events: none;
  }
  .merch-cta-label {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }
  .merch-cta-title {
    font-family: var(--heading);
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 12px;
  }
  .merch-cta-sub {
    font-family: var(--serif);
    font-size: clamp(15px, 2vw, 18px);
    font-style: italic;
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto 36px;
    line-height: 1.7;
  }
  .merch-cta-form {
    display: flex;
    gap: 0;
    max-width: 460px;
    margin: 0 auto;
  }
  .merch-cta-form input[type="email"] {
    flex: 1;
    padding: 14px 20px;
    font-family: var(--body);
    font-size: 15px;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--border);
    border-right: none;
    border-radius: 8px 0 0 8px;
    color: var(--white);
    outline: none;
    transition: border-color .3s, box-shadow .3s;
  }
  .merch-cta-form input[type="email"]::placeholder {
    color: var(--text-muted);
  }
  .merch-cta-form input[type="email"]:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(196,168,130,.1);
  }
  .merch-cta-form button {
    padding: 14px 28px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    background: var(--gold);
    color: var(--void);
    border: 1px solid var(--gold);
    border-radius: 0 8px 8px 0;
    cursor: pointer;
    transition: all .3s;
    white-space: nowrap;
  }
  .merch-cta-form button:hover {
    opacity: 0.85;
    box-shadow: 0 4px 20px rgba(196,168,130,.3);
  }
  .merch-cta-success {
    display: none;
    color: var(--gold);
    font-family: var(--serif);
    font-size: 18px;
    font-style: italic;
    margin-top: 20px;
  }
  .merch-cta-error {
    display: none;
    color: #c47070;
    font-family: var(--mono);
    font-size: 12px;
    margin-top: 12px;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 768px) {
    .merch-hero { padding: 40px 16px 16px; }
    .products-grid { grid-template-columns: 1fr; }
    .product-body { padding: 24px 20px; }
    .product-image-numeral { font-size: 56px; }
    .product-image-name { font-size: 22px; }
  }
  @media (max-width: 540px) {
    .merch-cta-form {
      flex-direction: column;
      gap: 10px;
    }
    .merch-cta-form input[type="email"] {
      border-right: 1px solid var(--border);
      border-radius: 8px;
    }
    .merch-cta-form button {
      border-radius: 8px;
    }
  }
</style>

<!-- ═══ HERO ═══ -->
<section class="merch-hero">
  <div class="wrap">
    <div class="merch-overline reveal d1">Wear the Philosophy</div>
    <h1 class="merch-title reveal d1">GRITHOS MERCH</h1>
    <p class="merch-subtitle reveal d2"><span class="gold">Do Right. Regardless.</span> — Wear it.</p>
  </div>
</section>

<div class="gold-divider"></div>

<!-- ═══ COLLECTION HEADER ═══ -->
<section class="collection-header">
  <div class="wrap">
    <div class="sec-label reveal d1">Now Available</div>
    <h2 class="sec-title reveal d1">The Four Pillars Collection</h2>
  </div>
</section>

<!-- ═══ PRODUCT GRID ═══ -->
<section class="products">
  <div class="wrap">
    <div class="products-grid">

      <!-- VIRTUE -->
      <div class="product-card reveal d1">
        <div class="product-image">
          <div class="product-image-numeral">I</div>
          <div class="product-image-name">Virtue</div>
        </div>
        <div class="product-body">
          <div class="product-pillar-label">Pillar I</div>
          <h3 class="product-name">Virtue</h3>
          <p class="product-quote">"I choose what is right over what is easy."</p>
          <a href="https://grithos.printful.me" target="_blank" rel="noopener" class="product-btn">Buy Now</a>
        </div>
      </div>

      <!-- APEX -->
      <div class="product-card reveal d2">
        <div class="product-image">
          <div class="product-image-numeral">II</div>
          <div class="product-image-name">Apex</div>
        </div>
        <div class="product-body">
          <div class="product-pillar-label">Pillar II</div>
          <h3 class="product-name">Apex</h3>
          <p class="product-quote">"I build when others rest."</p>
          <a href="https://grithos.printful.me" target="_blank" rel="noopener" class="product-btn">Buy Now</a>
        </div>
      </div>

      <!-- CONTROL -->
      <div class="product-card reveal d3">
        <div class="product-image">
          <div class="product-image-numeral">III</div>
          <div class="product-image-name">Control</div>
        </div>
        <div class="product-body">
          <div class="product-pillar-label">Pillar III</div>
          <h3 class="product-name">Control</h3>
          <p class="product-quote">"I do not let comfort dictate my choices."</p>
          <a href="https://grithos.printful.me" target="_blank" rel="noopener" class="product-btn">Buy Now</a>
        </div>
      </div>

      <!-- DEATH -->
      <div class="product-card reveal d4">
        <div class="product-image">
          <div class="product-image-numeral">IV</div>
          <div class="product-image-name">Death</div>
        </div>
        <div class="product-body">
          <div class="product-pillar-label">Pillar IV</div>
          <h3 class="product-name">Death</h3>
          <p class="product-quote">"I live as if this day demands an answer."</p>
          <a href="https://grithos.printful.me" target="_blank" rel="noopener" class="product-btn">Buy Now</a>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══ SHOP CTA ═══ -->
<section class="shop-cta-wrap reveal d1">
  <a href="https://grithos.printful.me" target="_blank" rel="noopener" class="shop-cta-btn">Shop the Collection →</a>
</section>

<div class="gold-divider"></div>

<!-- ═══ CTA ═══ -->
<section class="merch-cta" id="merch-notify">
  <div class="wrap">
    <div class="merch-cta-label reveal d1">Stay in the Loop</div>
    <h2 class="merch-cta-title reveal d2">Get notified when new designs drop.</h2>
    <p class="merch-cta-sub reveal d2">No spam. Just a heads-up when we release new gear.</p>
    <form class="merch-cta-form reveal d3" id="merchSubscribeForm">
      <input type="email" name="email" placeholder="Your email address" required />
      <button type="submit">Notify Me</button>
    </form>
    <p class="merch-cta-success" id="merchSignupSuccess">You're on the list. We'll let you know.</p>
    <p class="merch-cta-error" id="merchSignupError">Something went wrong. Please try again.</p>
  </div>
</section>

<script is:inline>
/* ═══ MERCH SUBSCRIBE FORM ═══ */
(function() {
  var form = document.getElementById('merchSubscribeForm');
  if (!form) return;
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var email = form.email.value;
    var btn = form.querySelector('button');
    var success = document.getElementById('merchSignupSuccess');
    var error = document.getElementById('merchSignupError');
    btn.textContent = '...';
    btn.disabled = true;
    error.style.display = 'none';
    try {
      var res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email })
      });
      if (res.ok) {
        form.style.display = 'none';
        success.style.display = 'block';
      } else {
        throw new Error('fail');
      }
    } catch(err) {
      error.style.display = 'block';
      btn.textContent = 'NOTIFY ME';
      btn.disabled = false;
    }
  });
})();
</script>

</BaseLayout>
