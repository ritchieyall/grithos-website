---
import BaseLayout from '../layouts/BaseLayout.astro';

const products = [
  { pillar: 'I', name: 'Virtue', back: '/assets/images/merch-virtue-back.jpg', quote: '"I choose what is right over what is easy."', delay: 'd1' },
  { pillar: 'II', name: 'Apex', back: '/assets/images/merch-apex-back.jpg', quote: '"I build when others rest."', delay: 'd2' },
  { pillar: 'III', name: 'Control', back: '/assets/images/merch-control-back.jpg', quote: '"I do not let comfort dictate my choices."', delay: 'd3' },
  { pillar: 'IV', name: 'Death', back: '/assets/images/merch-death-back.jpg', quote: '"I live as if this day demands an answer."', delay: 'd4' },
];
const frontImg = '/assets/images/merch-front.jpg';
const storeLink = 'https://grithos.printful.me';
---

<BaseLayout
  title="Merch | Grithos — The Five Pillars Collection"
  description="The Five Pillars Collection — T-shirts built on Virtue, Apex, Control, Death, and Verity. Do Right. Regardless. Wear it."
  ogTitle="Grithos Merch — The Five Pillars Collection"
  ogDescription="The Five Pillars Collection is live. Virtue. Apex. Control. Death. Verity. Do Right. Regardless. — Wear it."
  ogUrl="https://grithos.com/merch"
  canonical="https://grithos.com/merch"
  activePage="merch"
>

<style is:inline>
  /* ═══ MERCH HERO ═══ */
  .merch-hero {
    padding: 80px 0 28px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .merch-hero::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(196,168,130,.06) 0%, rgba(196,168,130,.02) 30%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .merch-hero .wrap {
    position: relative;
    z-index: 1;
  }
  .merch-overline {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }
  .merch-title {
    font-family: var(--heading);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 700;
    color: var(--white);
    letter-spacing: .02em;
    margin-bottom: 16px;
  }
  .merch-subtitle {
    font-family: var(--serif);
    font-size: clamp(16px, 2.2vw, 22px);
    font-style: italic;
    color: var(--text-secondary);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .merch-subtitle .gold { color: var(--gold); }

  /* ═══ COLLECTION LABEL ═══ */
  .collection-header {
    padding: 28px 0 12px;
    text-align: center;
  }

  /* ═══ PRODUCT GRID ═══ */
  .products {
    padding: 12px 0 40px;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    max-width: 820px;
    margin: 0 auto;
  }

  /* ═══ PRODUCT CARD ═══ */
  .product-card {
    background: linear-gradient(135deg, rgba(33,38,47,.9) 0%, rgba(28,32,41,.95) 100%);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: all .4s cubic-bezier(.16,1,.3,1);
    position: relative;
  }
  .product-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--gold) 50%, transparent 100%);
    opacity: 0;
    transition: opacity .4s;
    z-index: 2;
  }
  .product-card:hover {
    border-color: var(--gold-border);
    box-shadow: 0 8px 60px rgba(196,168,130,.06), 0 0 1px rgba(196,168,130,.2);
    transform: translateY(-4px);
  }
  .product-card:hover::before {
    opacity: 0.8;
  }

  /* Product image area */
  .product-image-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: #14161c;
  }
  .product-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity .4s ease;
  }
  .product-image-wrap .img-front {
    position: absolute;
    top: 0; left: 0;
    opacity: 0;
  }
  .product-card:hover .img-front {
    opacity: 1;
  }
  .product-card:hover .img-back {
    opacity: 0;
  }

  /* Price badge */
  .product-price-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 700;
    color: var(--void);
    background: var(--gold);
    padding: 5px 14px;
    border-radius: 4px;
    z-index: 1;
    letter-spacing: .04em;
  }

  /* Card body */
  .product-body {
    padding: 24px 20px 28px;
    text-align: center;
  }
  .product-pillar-label {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .22em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .product-name {
    font-family: var(--heading);
    font-size: 22px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 8px;
  }
  .product-quote {
    font-family: var(--serif);
    font-size: 14px;
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 20px;
    max-width: 300px;
    margin-left: auto;
    margin-right: auto;
  }
  .product-btn {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--void);
    background: var(--gold);
    border: 1px solid var(--gold);
    padding: 12px 32px;
    border-radius: 6px;
    cursor: pointer;
    text-decoration: none;
    transition: all .3s;
  }
  .product-btn:hover {
    opacity: 0.85;
    box-shadow: 0 4px 20px rgba(196,168,130,.3);
    transform: translateY(-1px);
  }

  /* ═══ ESSENTIALS GRID ═══ */
  .essentials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    max-width: 820px;
    margin: 0 auto;
  }
  .product-image-wrap--square {
    aspect-ratio: 1 / 1;
  }

  /* ═══ SHOP CTA BUTTON ═══ */
  .shop-cta-wrap {
    text-align: center;
    padding: 16px 0 40px;
  }
  .shop-cta-btn {
    display: inline-block;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--void);
    background: var(--gold);
    border: 2px solid var(--gold);
    padding: 18px 48px;
    border-radius: 8px;
    text-decoration: none;
    transition: all .3s;
  }
  .shop-cta-btn:hover {
    opacity: 0.85;
    box-shadow: 0 6px 30px rgba(196,168,130,.35);
    transform: translateY(-2px);
  }

  /* ═══ CTA SECTION ═══ */
  .merch-cta {
    padding: 28px 0 40px;
    text-align: center;
    position: relative;
  }
  .merch-cta::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 400px;
    background: radial-gradient(ellipse, rgba(196,168,130,.04) 0%, transparent 60%);
    pointer-events: none;
  }
  .merch-cta-label {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }
  .merch-cta-title {
    font-family: var(--heading);
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 12px;
  }
  .merch-cta-sub {
    font-family: var(--serif);
    font-size: clamp(15px, 2vw, 18px);
    font-style: italic;
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto 36px;
    line-height: 1.7;
  }
  .merch-cta-form {
    display: flex;
    gap: 0;
    max-width: 460px;
    margin: 0 auto;
  }
  .merch-cta-form input[type="email"] {
    flex: 1;
    padding: 14px 20px;
    font-family: var(--body);
    font-size: 15px;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--border);
    border-right: none;
    border-radius: 8px 0 0 8px;
    color: var(--white);
    outline: none;
    transition: border-color .3s, box-shadow .3s;
  }
  .merch-cta-form input[type="email"]::placeholder {
    color: var(--text-muted);
  }
  .merch-cta-form input[type="email"]:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(196,168,130,.1);
  }
  .merch-cta-form button {
    padding: 14px 28px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    background: var(--gold);
    color: var(--void);
    border: 1px solid var(--gold);
    border-radius: 0 8px 8px 0;
    cursor: pointer;
    transition: all .3s;
    white-space: nowrap;
  }
  .merch-cta-form button:hover {
    opacity: 0.85;
    box-shadow: 0 4px 20px rgba(196,168,130,.3);
  }
  .merch-cta-success {
    display: none;
    color: var(--gold);
    font-family: var(--serif);
    font-size: 18px;
    font-style: italic;
    margin-top: 20px;
  }
  .merch-cta-error {
    display: none;
    color: #c47070;
    font-family: var(--mono);
    font-size: 12px;
    margin-top: 12px;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 768px) {
    .merch-hero { padding: 40px 16px 16px; }
    .products-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
    .product-body { padding: 20px 16px 24px; }
    .product-name { font-size: 20px; }
    .essentials-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
  }
  @media (max-width: 540px) {
    .merch-cta-form {
      flex-direction: column;
      gap: 10px;
    }
    .merch-cta-form input[type="email"] {
      border-right: 1px solid var(--border);
      border-radius: 8px;
    }
    .merch-cta-form button {
      border-radius: 8px;
    }
  }
</style>

<!-- ═══ HERO ═══ -->
<section class="merch-hero">
  <div class="wrap">
    <img src="/assets/images/grithos-logo.png" alt="Grithos" class="merch-hero-logo reveal d1" style="max-width:180px;margin:0 auto 1.5rem;display:block;opacity:0.95;" />
    <div class="merch-overline reveal d1">Wear the Philosophy</div>
    <p class="merch-subtitle reveal d2"><span class="gold">Do Right. Regardless.</span> — Wear it.</p>
  </div>
</section>

<div class="gold-divider"></div>

<!-- ═══ COLLECTION HEADER ═══ -->
<section class="collection-header">
  <div class="wrap">
    <div class="sec-label reveal d1">Now Available</div>
    <h2 class="sec-title reveal d1">The Five Pillars Collection</h2>
  </div>
</section>

<!-- ═══ PRODUCT GRID ═══ -->
<section class="products">
  <div class="wrap">
    <div class="products-grid">
      {products.map((p) => (
        <div class={`product-card reveal ${p.delay}`}>
          <div class="product-image-wrap">
            <span class="product-price-badge">$32</span>
            <img class="img-back" src={p.back} alt={`Grithos ${p.name} Pillar T-Shirt — Back Design`} loading="lazy" width="600" height="600" />
            <img class="img-front" src={frontImg} alt={`Grithos ${p.name} Pillar T-Shirt — Front`} loading="lazy" width="600" height="600" />
          </div>
          <div class="product-body">
            <div class="product-pillar-label">Pillar {p.pillar}</div>
            <h3 class="product-name">{p.name}</h3>
            <p class="product-quote">{p.quote}</p>
            <a href={storeLink} target="_blank" rel="noopener" class="product-btn">Buy Now</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ SHOP CTA ═══ -->
<section class="shop-cta-wrap reveal d1">
  <a href={storeLink} target="_blank" rel="noopener" class="shop-cta-btn">Shop the Collection →</a>
</section>

<div class="gold-divider"></div>

<!-- ═══ ESSENTIALS HEADER ═══ -->
<section class="collection-header">
  <div class="wrap">
    <div class="sec-label reveal d1">New</div>
    <h2 class="sec-title reveal d1">Essentials</h2>
  </div>
</section>

<!-- ═══ ESSENTIALS GRID ═══ -->
<section class="products">
  <div class="wrap">
    <div class="essentials-grid">
      <div class="product-card reveal d1">
        <div class="product-image-wrap product-image-wrap--square">
          <span class="product-price-badge">$22</span>
          <img class="img-back" src="/assets/images/merch-mug-front.jpg" alt="Grithos Mug — Front" loading="lazy" width="600" height="600" />
          <img class="img-front" src="/assets/images/merch-mug-side.jpg" alt="Grithos Mug — Side" loading="lazy" width="600" height="600" />
        </div>
        <div class="product-body">
          <div class="product-pillar-label">Daily Essential</div>
          <h3 class="product-name">Grithos Mug</h3>
          <p class="product-quote">"Start every morning with intention."</p>
          <a href={storeLink} target="_blank" rel="noopener" class="product-btn">Buy Now</a>
        </div>
      </div>
      <div class="product-card reveal d2">
        <div class="product-image-wrap product-image-wrap--square">
          <span class="product-price-badge">$26</span>
          <img class="img-back" src="/assets/images/merch-journal-front.jpg" alt="Grithos Journal — Front" loading="lazy" width="600" height="600" />
          <img class="img-front" src="/assets/images/merch-journal-side.jpg" alt="Grithos Journal — Side" loading="lazy" width="600" height="600" />
        </div>
        <div class="product-body">
          <div class="product-pillar-label">Daily Essential</div>
          <h3 class="product-name">Grithos Journal</h3>
          <p class="product-quote">"Every philosophy needs practice. Every practice needs a page."</p>
          <a href={storeLink} target="_blank" rel="noopener" class="product-btn">Buy Now</a>
        </div>
      </div>
    </div>
  </div>
</section>



</BaseLayout>
