  var now = new Date();
  var currentMonth = now.getMonth();
  var currentDay = now.getDate();
  var selectedDay = null;
  var viewMonth = currentMonth;
  var practiceRow = null;

  var grid = document.getElementById('cal-grid');
  var titleEl = document.getElementById('month-title');
  var tenetEl = document.getElementById('month-tenet');
  var prevBtn = document.getElementById('prev-month');
  var nextBtn = document.getElementById('next-month');
  var todayBtn = document.getElementById('today-btn');

  function daysInMonth(m) {
    return new Date(2026, m + 1, 0).getDate();
  }

  function firstDayOfMonth(m) {
    return new Date(2026, m, 1).getDay();
  }

  function closePractice() {
    if (practiceRow) {
      practiceRow.classList.remove('open');
      setTimeout(function() {
        if (practiceRow && practiceRow.parentNode) {
          practiceRow.parentNode.removeChild(practiceRow);
        }
        practiceRow = null;
      }, 350);
    }
    selectedDay = null;
    var allDays = grid.querySelectorAll('.cal-day:not(.empty)');
    for (var i = 0; i < allDays.length; i++) {
      allDays[i].classList.remove('active');
    }
  }

  function renderMonth() {
    titleEl.textContent = MONTHS[viewMonth];
    tenetEl.textContent = TENETS[viewMonth];
    grid.innerHTML = '';
    practiceRow = null;

    var start = firstDayOfMonth(viewMonth);
    var days = daysInMonth(viewMonth);

    for (var i = 0; i < start; i++) {
      var empty = document.createElement('div');
      empty.className = 'cal-day empty';
      grid.appendChild(empty);
    }

    for (var d = 1; d <= days; d++) {
      var cell = document.createElement('div');
      cell.className = 'cal-day';
      cell.textContent = d;
      if (viewMonth === currentMonth && d === currentDay) {
        cell.classList.add('today');
      }
      if (viewMonth === 2 && d === 13) {
        cell.classList.add('forge-day');
      }
      (function(day) {
        cell.addEventListener('click', function() {
          selectDay(day);
        });
      })(d);
      grid.appendChild(cell);
    }
  }

  function getRowEndIndex(dayIndex) {
    // dayIndex is 0-based position in grid (including empty cells)
    // Find the last cell in this row (rows of 7)
    var row = Math.floor(dayIndex / 7);
    var rowEnd = (row + 1) * 7 - 1;
    var totalCells = grid.children.length;
    // Don't count existing practice rows
    if (practiceRow && practiceRow.parentNode === grid) {
      totalCells--;
    }
    return Math.min(rowEnd, totalCells - 1);
  }

  function selectDay(day) {
    // If clicking the same day, close it
    if (selectedDay === day && practiceRow) {
      closePractice();
      return;
    }

    // Remove old practice row immediately
    if (practiceRow && practiceRow.parentNode) {
      practiceRow.parentNode.removeChild(practiceRow);
      practiceRow = null;
    }

    // Clear old active states
    var allDays = grid.querySelectorAll('.cal-day:not(.empty)');
    for (var i = 0; i < allDays.length; i++) {
      allDays[i].classList.remove('active');
    }

    selectedDay = day;
    allDays[day - 1].classList.add('active');

    var practices = PRACTICES[viewMonth];
    if (!practices || !practices[day - 1]) return;

    var isForgeDay = (viewMonth === 2 && day === 13);

    // Calculate grid position of clicked day
    var start = firstDayOfMonth(viewMonth);
    var gridIndex = start + day - 1;
    var rowEndIndex = getRowEndIndex(gridIndex);

    // Create the practice row
    practiceRow = document.createElement('div');
    practiceRow.className = 'practice-row';
    var cardClass = isForgeDay ? 'practice-card forge-card' : 'practice-card';
    var forgeLabel = isForgeDay ? '<div class="forge-label">FORGE DAY</div>' : '';
    var dateLabel = isForgeDay ? 'MARCH 13 — THE FOUNDING' : MONTHS[viewMonth] + ' ' + day;
    practiceRow.innerHTML =
      '<div class="' + cardClass + '">' +
        '<button class="close-btn" aria-label="Close">&times;</button>' +
        forgeLabel +
        '<div class="practice-date">' + dateLabel + '</div>' +
        '<div class="practice-text">' + practices[day - 1] + '</div>' +
        '<div class="practice-tenet-link"><a href="/tenets#' + TENET_IDS[viewMonth] + '">' + TENETS[viewMonth].replace('— ', '— ').split('—')[0].trim() + '</a></div>' +
        '<button class="share-btn" aria-label="Share this practice">' +
          '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="14" height="14"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" /></svg>' +
          ' Share' +
        '</button>' +
      '</div>';

    practiceRow.querySelector('.close-btn').addEventListener('click', function(e) {
      e.stopPropagation();
      closePractice();
    });

    practiceRow.querySelector('.share-btn').addEventListener('click', function(e) {
      e.stopPropagation();
      generateShareCard(practices[day - 1], TENETS[viewMonth], MONTHS[viewMonth] + ' ' + day, isForgeDay);
    });

    // Insert after the last cell in this row
    var cells = grid.children;
    if (rowEndIndex + 1 < cells.length) {
      grid.insertBefore(practiceRow, cells[rowEndIndex + 1]);
    } else {
      grid.appendChild(practiceRow);
    }

    // Trigger animation on next frame
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        practiceRow.classList.add('open');
      });
    });
  }

  function generateShareCard(practice, tenet, dateStr, isForge) {
    var canvas = document.createElement('canvas');
    canvas.width = 1080;
    canvas.height = 1080;
    var ctx = canvas.getContext('2d');

    // Background
    ctx.fillStyle = '#1c2029';
    ctx.fillRect(0, 0, 1080, 1080);

    // Gold top line
    var grad = ctx.createLinearGradient(0, 0, 1080, 0);
    grad.addColorStop(0, 'transparent');
    grad.addColorStop(0.5, '#c9935a');
    grad.addColorStop(1, 'transparent');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, 1080, 4);

    // Date
    ctx.fillStyle = '#c9935a';
    ctx.font = '600 22px sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(dateStr.toUpperCase(), 540, isForge ? 200 : 240);

    // Forge badge
    if (isForge) {
      ctx.fillStyle = '#c9935a';
      var badgeWidth = 180;
      var badgeHeight = 36;
      var bx = 540 - badgeWidth / 2;
      var by = 140;
      ctx.beginPath();
      ctx.roundRect(bx, by, badgeWidth, badgeHeight, 6);
      ctx.fill();
      ctx.fillStyle = '#1c2029';
      ctx.font = '700 14px sans-serif';
      ctx.fillText('FORGE DAY', 540, 164);
    }

    // Tenet
    ctx.fillStyle = '#70685e';
    ctx.font = '500 16px sans-serif';
    ctx.fillText(tenet.split('—')[0].trim(), 540, isForge ? 250 : 280);

    // Practice text - word wrap
    ctx.fillStyle = '#f5f0eb';
    ctx.font = '700 38px sans-serif';
    ctx.textAlign = 'center';
    var words = practice.split(' ');
    var lines = [];
    var line = '';
    var maxWidth = 860;
    for (var w = 0; w < words.length; w++) {
      var test = line + words[w] + ' ';
      if (ctx.measureText(test).width > maxWidth && line) {
        lines.push(line.trim());
        line = words[w] + ' ';
      } else {
        line = test;
      }
    }
    lines.push(line.trim());

    var lineHeight = 54;
    var startY = 540 - (lines.length * lineHeight) / 2;
    for (var l = 0; l < lines.length; l++) {
      ctx.fillText(lines[l], 540, startY + l * lineHeight);
    }

    // Branding
    ctx.fillStyle = '#70685e';
    ctx.font = '600 18px sans-serif';
    ctx.fillText('GRITHOS', 540, 940);
    ctx.fillStyle = '#4a443c';
    ctx.font = '400 14px sans-serif';
    ctx.fillText('grithos.com', 540, 970);

    // Bottom gold line
    ctx.fillStyle = grad;
    ctx.fillRect(0, 1076, 1080, 4);

    // Share or download
    canvas.toBlob(function(blob) {
      if (navigator.share && navigator.canShare) {
        var file = new File([blob], 'grithos-practice.png', { type: 'image/png' });
        var shareData = { files: [file], title: 'Grithos Daily Practice', text: practice };
        if (navigator.canShare(shareData)) {
          navigator.share(shareData).catch(function() {});
          return;
        }
      }
      // Fallback: download
      var a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'grithos-practice.png';
      a.click();
      URL.revokeObjectURL(a.href);
    }, 'image/png');
  }

  prevBtn.addEventListener('click', function() {
    viewMonth = viewMonth === 0 ? 11 : viewMonth - 1;
    selectedDay = null;
    renderMonth();
  });

  nextBtn.addEventListener('click', function() {
    viewMonth = viewMonth === 11 ? 0 : viewMonth + 1;
    selectedDay = null;
    renderMonth();
  });

  todayBtn.addEventListener('click', function() {
    viewMonth = currentMonth;
    renderMonth();
    selectDay(currentDay);
  });

  renderMonth();
  selectDay(currentDay);
})();
</script>

</BaseLayout>
