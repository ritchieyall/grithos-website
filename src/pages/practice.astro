---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="The Daily Practice | Grithos"
  description="365 daily practices for living with grit and ethos. One simple action per day, one tenet per month. An interactive calendar for a full year of becoming a Grithosian."
  ogTitle="The Daily Practice — Grithos"
  ogDescription="365 daily practices. One simple action per day, one tenet per month. An interactive calendar for a full year of becoming."
  ogUrl="https://grithos.com/practice"
  canonical="https://grithos.com/practice"
  activePage="practice"
>

<style is:inline>
  .page-hero {
    padding: 160px 0 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .page-hero::before {
    content: '';
    position: absolute;
    top: 40%; left: 50%; transform: translateX(-50%);
    width: 800px; height: 800px;
    background: radial-gradient(circle, rgba(201,147,90,.05) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .page-hero .label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
    position: relative;
  }
  .page-hero h1 {
    font-family: var(--heading);
    font-size: clamp(2rem, 5vw, 3.2rem);
    color: var(--white);
    font-weight: 700;
    line-height: 1.15;
    position: relative;
  }
  .page-hero .subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    font-style: italic;
    margin-top: 16px;
    position: relative;
  }

  /* Calendar controls */
  .calendar-section {
    padding: 40px 0 100px;
  }
  .month-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-bottom: 12px;
  }
  .month-nav button {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  .month-nav button:hover {
    border-color: var(--gold);
    color: var(--gold);
  }
  .month-title {
    font-family: var(--heading);
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    color: var(--white);
    font-weight: 700;
    min-width: 280px;
    text-align: center;
  }
  .month-tenet {
    text-align: center;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 32px;
  }

  /* Calendar grid */
  .cal-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    margin-bottom: 4px;
  }
  .cal-weekdays span {
    text-align: center;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 1px;
    padding: 8px 0;
  }
  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-secondary);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r);
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
  }
  .cal-day:hover {
    border-color: var(--gold);
    color: var(--gold);
    background: var(--gold-soft);
  }
  .cal-day.today {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(201,147,90,.12);
  }
  .cal-day.active {
    background: var(--gold);
    color: var(--void);
    border-color: var(--gold);
  }
  .cal-day.empty {
    background: transparent;
    border-color: transparent;
    cursor: default;
  }
  .cal-day.forge-day {
    background: linear-gradient(135deg, rgba(201,147,90,.25), rgba(201,147,90,.08));
    border-color: var(--gold);
    color: var(--gold);
    position: relative;
    overflow: visible;
  }
  .cal-day.forge-day::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gold);
  }
  .cal-day.forge-day.active {
    background: var(--gold);
    color: var(--void);
  }
  .cal-day.forge-day.active::after {
    background: var(--void);
  }
  .practice-card.forge-card {
    border-color: var(--gold);
    background: linear-gradient(135deg, var(--card), rgba(201,147,90,.06));
    animation: forgeGlow 0.8s ease;
  }
  @keyframes forgeGlow {
    0% { box-shadow: 0 0 0 0 rgba(201,147,90,0); }
    40% { box-shadow: 0 0 30px 4px rgba(201,147,90,.25); }
    100% { box-shadow: 0 0 8px 1px rgba(201,147,90,.1); }
  }
  .practice-card.forge-card .practice-date {
    color: var(--gold-light);
  }
  .forge-label {
    display: inline-block;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--void);
    background: var(--gold);
    padding: 3px 10px;
    border-radius: 3px;
    margin-bottom: 12px;
  }

  /* Inline practice row — inserted into the calendar grid */
  .practice-row {
    grid-column: 1 / -1;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.4s cubic-bezier(.16,1,.3,1), opacity 0.3s ease;
    opacity: 0;
  }
  .practice-row.open {
    max-height: 300px;
    opacity: 1;
  }
  .practice-card {
    margin: 4px 0;
    padding: 28px 32px;
    background: var(--card);
    border: 1px solid var(--gold-border);
    border-radius: var(--r-lg);
    position: relative;
    animation: cardGlow 0.5s ease;
  }
  @keyframes cardGlow {
    0% { box-shadow: 0 0 0 0 rgba(201,147,90,0); }
    50% { box-shadow: 0 0 20px 2px rgba(201,147,90,.15); }
    100% { box-shadow: 0 0 0 0 rgba(201,147,90,0); }
  }
  .practice-card .practice-date {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
  }
  .practice-card .practice-text {
    font-family: var(--heading);
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    color: var(--white);
    font-weight: 600;
    line-height: 1.5;
  }
  .practice-card .practice-tenet-link {
    margin-top: 14px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .practice-card .practice-tenet-link a {
    color: var(--gold);
    text-decoration: none;
  }
  .practice-card .practice-tenet-link a:hover {
    text-decoration: underline;
  }
  .practice-card .close-btn {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 18px;
    cursor: pointer;
    padding: 4px;
    line-height: 1;
    transition: color 0.2s;
  }
  .practice-card .close-btn:hover {
    color: var(--gold);
  }

  /* Today button */
  .today-btn {
    display: block;
    margin: 20px auto 0;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 8px 20px;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .today-btn:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 6px;
    cursor: pointer;
    margin-top: 12px;
    transition: all 0.2s;
  }
  .share-btn:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  @media (max-width: 600px) {
    .cal-day {
      font-size: 0.85rem;
    }
    .practice-card {
      padding: 20px;
    }
    .month-nav button {
      width: 36px;
      height: 36px;
    }
  }
</style>

<section class="page-hero">
  <div class="wrap">
    <p class="label reveal">THE DAILY PRACTICE</p>
    <h1 class="reveal d1">365 Days. 12 Tenets.<br>One Year of Becoming.</h1>
    <p class="subtitle reveal d2">Each month dedicates itself to one tenet. Each day gives you one practice. No preaching. No excuses. Just action.</p>
  </div>
</section>

<section class="calendar-section">
  <div class="wrap">
    <div class="month-nav reveal">
      <button id="prev-month" aria-label="Previous month">&#8592;</button>
      <div class="month-title" id="month-title">January</div>
      <button id="next-month" aria-label="Next month">&#8594;</button>
    </div>
    <div class="month-tenet" id="month-tenet">TENET I — TELL THE TRUTH</div>
    <div class="cal-weekdays reveal d1">
      <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
    </div>
    <div class="cal-grid reveal d2" id="cal-grid"></div>
    <button class="today-btn reveal d3" id="today-btn">Today</button>
  </div>
</section>

