---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Forge Leader Scripts — The Forge"
  description="15 ready-to-run meeting scripts for Forge chapter leaders. Pick a week, print it, run the meeting. Pillar → Tenet → Architect → Practice."
  activePage="the-forge"
>

<section class="scripts-hero">
  <div class="wrap">
    <div class="hero-content reveal">
      <p class="section-overline">The Forge · Leader Scripts</p>
      <h1>Run the Meeting.</h1>
      <div class="hero-line"></div>
      <p class="hero-sub">15 packages. One per meeting. Pick your week, hit print, run The Forge. No training required.</p>
      <p class="hero-chain">Pillar <span class="arrow">→</span> Tenet <span class="arrow">→</span> Architect + Quote <span class="arrow">→</span> Practice</p>
      <p class="hero-sub-small">The why → The rule → The proof it works → One action, today.</p>
    </div>
  </div>
</section>

<hr class="gold-divider" />

<section class="scripts-grid-section">
  <div class="wrap">
    <div class="pillar-filter reveal">
      <button class="filter-btn active" data-filter="all">All 15</button>
      <button class="filter-btn" data-filter="virtue">I · Virtue</button>
      <button class="filter-btn" data-filter="apex">II · Apex</button>
      <button class="filter-btn" data-filter="control">III · Control</button>
      <button class="filter-btn" data-filter="death">IV · Death</button>
      <button class="filter-btn" data-filter="verity">V · Verity</button>
    </div>

    <div class="scripts-grid">

      <!-- PILLAR I — VIRTUE -->
      <div class="script-card reveal" data-pillar="virtue" data-week="1">
        <div class="card-header">
          <span class="week-badge">Week 1</span>
          <span class="pillar-badge virtue">Virtue</span>
        </div>
        <h3>Tell the Truth. Even When It Costs You.</h3>
        <p class="architect-name">Marcus Aurelius</p>
        <p class="architect-era">Emperor of Rome · 121–180 AD</p>
        <button class="btn-print" onclick="openPrint(1)">Print This Script →</button>
      </div>

      <div class="script-card reveal d1" data-pillar="virtue" data-week="2">
        <div class="card-header">
          <span class="week-badge">Week 2</span>
          <span class="pillar-badge virtue">Virtue</span>
        </div>
        <h3>Keep Your Word Like Your Life Depends on It.</h3>
        <p class="architect-name">Benjamin Franklin</p>
        <p class="architect-era">Founding Father · 1706–1790</p>
        <button class="btn-print" onclick="openPrint(2)">Print This Script →</button>
      </div>

      <div class="script-card reveal d2" data-pillar="virtue" data-week="3">
        <div class="card-header">
          <span class="week-badge">Week 3</span>
          <span class="pillar-badge virtue">Virtue</span>
        </div>
        <h3>Own Your Wins. But Do Right in the Dark.</h3>
        <p class="architect-name">Abraham Lincoln</p>
        <p class="architect-era">16th President · 1809–1865</p>
        <button class="btn-print" onclick="openPrint(3)">Print This Script →</button>
      </div>

      <!-- PILLAR II — APEX -->
      <div class="script-card reveal" data-pillar="apex" data-week="4">
        <div class="card-header">
          <span class="week-badge">Week 4</span>
          <span class="pillar-badge apex">Apex</span>
        </div>
        <h3>Never Shrink. Never Apologize for Strength.</h3>
        <p class="architect-name">Theodore Roosevelt</p>
        <p class="architect-era">26th President · 1858–1919</p>
        <button class="btn-print" onclick="openPrint(4)">Print This Script →</button>
      </div>

      <div class="script-card reveal d1" data-pillar="apex" data-week="5">
        <div class="card-header">
          <span class="week-badge">Week 5</span>
          <span class="pillar-badge apex">Apex</span>
        </div>
        <h3>Protect Those Beneath You.</h3>
        <p class="architect-name">Frederick Douglass</p>
        <p class="architect-era">Abolitionist · 1818–1895</p>
        <button class="btn-print" onclick="openPrint(5)">Print This Script →</button>
      </div>

      <div class="script-card reveal d2" data-pillar="apex" data-week="6">
        <div class="card-header">
          <span class="week-badge">Week 6</span>
          <span class="pillar-badge apex">Apex</span>
        </div>
        <h3>Reject the Victim. Become the Author.</h3>
        <p class="architect-name">Viktor Frankl</p>
        <p class="architect-era">Psychiatrist, Holocaust Survivor · 1905–1997</p>
        <button class="btn-print" onclick="openPrint(6)">Print This Script →</button>
      </div>

      <!-- PILLAR III — CONTROL -->
      <div class="script-card reveal" data-pillar="control" data-week="7">
        <div class="card-header">
          <span class="week-badge">Week 7</span>
          <span class="pillar-badge control">Control</span>
        </div>
        <h3>Own Only What Is Yours.</h3>
        <p class="architect-name">Epictetus</p>
        <p class="architect-era">Former Slave, Stoic Philosopher · 50–135 AD</p>
        <button class="btn-print" onclick="openPrint(7)">Print This Script →</button>
      </div>

      <div class="script-card reveal d1" data-pillar="control" data-week="8">
        <div class="card-header">
          <span class="week-badge">Week 8</span>
          <span class="pillar-badge control">Control</span>
        </div>
        <h3>Redirect Immediately.</h3>
        <p class="architect-name">Sun Tzu</p>
        <p class="architect-era">Military Strategist · 544–496 BC</p>
        <button class="btn-print" onclick="openPrint(8)">Print This Script →</button>
      </div>

      <div class="script-card reveal d2" data-pillar="control" data-week="9">
        <div class="card-header">
          <span class="week-badge">Week 9</span>
          <span class="pillar-badge control">Control</span>
        </div>
        <h3>Trust the Bounds.</h3>
        <p class="architect-name">Lao Tzu</p>
        <p class="architect-era">Chinese Philosopher · 6th Century BC</p>
        <button class="btn-print" onclick="openPrint(9)">Print This Script →</button>
      </div>

      <!-- PILLAR IV — DEATH -->
      <div class="script-card reveal" data-pillar="death" data-week="10">
        <div class="card-header">
          <span class="week-badge">Week 10</span>
          <span class="pillar-badge death">Death</span>
        </div>
        <h3>Live Like You Will Die. Because You Will.</h3>
        <p class="architect-name">Seneca</p>
        <p class="architect-era">Roman Statesman · 4 BC–65 AD</p>
        <button class="btn-print" onclick="openPrint(10)">Print This Script →</button>
      </div>

      <div class="script-card reveal d1" data-pillar="death" data-week="11">
        <div class="card-header">
          <span class="week-badge">Week 11</span>
          <span class="pillar-badge death">Death</span>
        </div>
        <h3>Grieve Fully. Then Move.</h3>
        <p class="architect-name">Albert Camus</p>
        <p class="architect-era">Novelist, Philosopher · 1913–1960</p>
        <button class="btn-print" onclick="openPrint(11)">Print This Script →</button>
      </div>

      <div class="script-card reveal d2" data-pillar="death" data-week="12">
        <div class="card-header">
          <span class="week-badge">Week 12</span>
          <span class="pillar-badge death">Death</span>
        </div>
        <h3>Build a Legacy That Stands in This Life.</h3>
        <p class="architect-name">Paul Graham</p>
        <p class="architect-era">Co-founder of Y Combinator · 1964–Present</p>
        <button class="btn-print" onclick="openPrint(12)">Print This Script →</button>
      </div>

      <!-- PILLAR V — VERITY -->
      <div class="script-card reveal" data-pillar="verity" data-week="13">
        <div class="card-header">
          <span class="week-badge">Week 13</span>
          <span class="pillar-badge verity">Verity</span>
        </div>
        <h3>The World Engineers Your Comfort. Master It Anyway.</h3>
        <p class="architect-name">Tristan Harris</p>
        <p class="architect-era">Center for Humane Technology · 1984–Present</p>
        <button class="btn-print" onclick="openPrint(13)">Print This Script →</button>
      </div>

      <div class="script-card reveal d1" data-pillar="verity" data-week="14">
        <div class="card-header">
          <span class="week-badge">Week 14</span>
          <span class="pillar-badge verity">Verity</span>
        </div>
        <h3>Build With. Never Build Under.</h3>
        <p class="architect-name">Andrej Karpathy</p>
        <p class="architect-era">AI Researcher & Educator · 1986–Present</p>
        <button class="btn-print" onclick="openPrint(14)">Print This Script →</button>
      </div>

      <div class="script-card reveal d2" data-pillar="verity" data-week="15">
        <div class="card-header">
          <span class="week-badge">Week 15</span>
          <span class="pillar-badge verity">Verity</span>
        </div>
        <h3>Walk Forward. Eyes Open.</h3>
        <p class="architect-name">Socrates</p>
        <p class="architect-era">Greek Philosopher · 470–399 BC</p>
        <button class="btn-print" onclick="openPrint(15)">Print This Script →</button>
      </div>

    </div>
  </div>
</section>

<!-- PRINT OVERLAYS — one per week, hidden until triggered -->
<div id="print-overlay" class="print-overlay" style="display:none;">
  <div class="print-sheet" id="print-sheet">
    <div class="print-close" onclick="closePrint()">✕</div>
    <div class="print-header">
      <img src="/assets/images/grithos-logo.png" alt="Grithos" class="print-logo">
      <div class="print-title">THE FORGE — LEADER SCRIPT</div>
      <div class="print-week" id="print-week-label"></div>
    </div>
    <div class="print-body" id="print-body"></div>
    <div class="print-footer">
      <button class="btn btn-primary no-print" onclick="window.print()">🖨 Print This Page</button>
      <p class="print-url no-print">grithos.com/the-forge</p>
    </div>
  </div>
</div>

</BaseLayout>

