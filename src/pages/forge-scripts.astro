function openPrint(week) {
  var s = scripts[week];
  document.getElementById('print-week-label').textContent = s.week + ' · ' + s.tenet;
  document.getElementById('print-body').innerHTML =
    '<div class="print-section">' +
      '<div class="print-label">THE PILLAR</div>' +
      '<div class="print-pillar-name">' + s.pillar + '</div>' +
      '<div class="print-pillar-sub">' + s.pillarSub + '</div>' +
      '<p class="print-pillar-desc">' + s.pillarDesc + '</p>' +
    '</div>' +
    '<div class="print-divider"></div>' +
    '<div class="print-section">' +
      '<div class="print-label">THE TENET</div>' +
      '<div class="print-tenet-title">' + s.tenentTitle + '</div>' +
      '<p>' + s.tenentDesc + '</p>' +
    '</div>' +
    '<div class="print-divider"></div>' +
    '<div class="print-section">' +
      '<div class="print-label">THE ARCHITECT</div>' +
      '<div class="print-architect">' + s.architect + '</div>' +
      '<div class="print-architect-life">' + s.architectLife + '</div>' +
      '<blockquote>"' + s.quote + '"</blockquote>' +
      '<div class="print-quote-source">— ' + s.quoteSource + '</div>' +
    '</div>' +
    '<div class="print-divider"></div>' +
    '<div class="print-section">' +
      '<div class="print-label">THE PRACTICE</div>' +
      '<p class="print-practice">' + s.practice + '</p>' +
    '</div>';
  document.getElementById('print-overlay').style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closePrint() {
  document.getElementById('print-overlay').style.display = 'none';
  document.body.style.overflow = '';
}

// Filter buttons
document.querySelectorAll('.filter-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    var filter = btn.getAttribute('data-filter');
    document.querySelectorAll('.script-card').forEach(function(card) {
      if (filter === 'all' || card.getAttribute('data-pillar') === filter) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  });
});

// Close on escape
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closePrint();
});
</script>

