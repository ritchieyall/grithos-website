/* ═══ HERO ═══ */
.scripts-hero { padding: 120px 0 48px; text-align: center; }
.hero-content { max-width: 720px; margin: 0 auto; }
.hero-content h1 { font-family: var(--heading); font-size: clamp(40px, 6vw, 64px); font-weight: 700; color: var(--white); margin-bottom: 16px; }
.hero-line { width: 60px; height: 2px; background: var(--gold); margin: 0 auto 20px; }
.hero-sub { font-size: 17px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 16px; }
.hero-chain { font-family: var(--mono); font-size: 14px; color: var(--gold); letter-spacing: .05em; margin-bottom: 8px; }
.hero-chain .arrow { color: var(--text-muted); }
.hero-sub-small { font-size: 14px; color: var(--text-muted); font-style: italic; }

/* ═══ FILTER ═══ */
.scripts-grid-section { padding: 48px 0 80px; }
.pillar-filter { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px; justify-content: center; }
.filter-btn {
  font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
  background: transparent; border: 1px solid var(--border); color: var(--text-secondary);
  padding: 8px 16px; border-radius: 6px; cursor: pointer; transition: all .2s;
}
.filter-btn:hover { border-color: var(--border-hover); color: var(--white); }
.filter-btn.active { background: var(--gold); color: var(--void); border-color: var(--gold); }

/* ═══ CARD GRID ═══ */
.scripts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.script-card {
  background: var(--card); border: 1px solid var(--border); border-radius: 12px;
  padding: 28px 24px; transition: border-color .3s, transform .3s;
  display: flex; flex-direction: column;
}
.script-card:hover { border-color: var(--gold-border); transform: translateY(-3px); }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.week-badge { font-family: var(--mono); font-size: 11px; color: var(--text-muted); letter-spacing: .1em; }
.pillar-badge { font-family: var(--mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; padding: 3px 8px; border-radius: 4px; }
.pillar-badge.virtue { background: rgba(184,168,142,.15); color: var(--gold); }
.pillar-badge.apex { background: rgba(220,120,80,.15); color: #dc7850; }
.pillar-badge.control { background: rgba(100,160,200,.15); color: #64a0c8; }
.pillar-badge.death { background: rgba(160,130,180,.15); color: #a082b4; }
.pillar-badge.verity { background: rgba(100,200,160,.15); color: #64c8a0; }
.script-card h3 { font-family: var(--heading); font-size: 20px; color: var(--white); line-height: 1.3; margin-bottom: 12px; flex-grow: 1; }
.architect-name { font-family: var(--heading); font-size: 16px; color: var(--gold); font-style: italic; margin-bottom: 2px; }
.architect-era { font-size: 12px; color: var(--text-muted); margin-bottom: 16px; }
.btn-print {
  font-family: var(--mono); font-size: 11px; letter-spacing: .08em;
  background: transparent; border: 1px solid var(--border); color: var(--text-secondary);
  padding: 10px 16px; border-radius: 6px; cursor: pointer; transition: all .2s; text-align: center;
}
.btn-print:hover { border-color: var(--gold); color: var(--gold); }

/* ═══ PRINT OVERLAY ═══ */
.print-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 9999;
  background: rgba(0,0,0,.85); display: flex; align-items: center; justify-content: center;
  padding: 20px; overflow-y: auto;
}
.print-sheet {
  background: #fff; color: #111; max-width: 680px; width: 100%;
  border-radius: 12px; padding: 48px 40px; position: relative;
  font-family: 'Source Sans 3', sans-serif; line-height: 1.6;
}
.print-close {
  position: absolute; top: 16px; right: 20px; font-size: 24px; color: #999;
  cursor: pointer; transition: color .2s; line-height: 1;
}
.print-close:hover { color: #333; }
.print-header { text-align: center; margin-bottom: 32px; border-bottom: 2px solid #b8a88e; padding-bottom: 20px; }
.print-logo { width: 32px; height: 32px; margin-bottom: 8px; }
.print-title { font-family: 'Cormorant Garamond', serif; font-size: 14px; letter-spacing: .2em; text-transform: uppercase; color: #b8a88e; margin-bottom: 4px; }
.print-week { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #888; letter-spacing: .1em; }
.print-section { margin-bottom: 24px; }
.print-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: .25em; text-transform: uppercase; color: #b8a88e; margin-bottom: 8px; }
.print-pillar-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 700; color: #222; }
.print-pillar-sub { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-style: italic; color: #666; margin-bottom: 8px; }
.print-pillar-desc { font-size: 15px; color: #444; }
.print-tenet-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 700; color: #222; margin-bottom: 8px; }
.print-section p { font-size: 15px; color: #444; }
.print-architect { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; color: #222; }
.print-architect-life { font-size: 13px; color: #888; margin-bottom: 12px; }
.print-section blockquote { border-left: 3px solid #b8a88e; padding: 12px 20px; margin: 12px 0; font-family: 'Cormorant Garamond', serif; font-size: 18px; font-style: italic; color: #333; }
.print-quote-source { font-size: 12px; color: #999; text-align: right; }
.print-practice { font-size: 17px; color: #222; font-weight: 500; line-height: 1.7; }
.print-divider { height: 1px; background: #e0ddd8; margin: 20px 0; }
.print-footer { text-align: center; margin-top: 32px; padding-top: 20px; border-top: 1px solid #e0ddd8; }
.print-url { font-size: 12px; color: #999; margin-top: 12px; }

/* ═══ PRINT MEDIA ═══ */
@media print {
  body, body * { visibility: hidden !important; }
  .print-overlay, .print-overlay * { visibility: visible !important; }
  .print-overlay { position: absolute; background: white; padding: 0; }
  .print-sheet { box-shadow: none; border-radius: 0; padding: 24px; }
  .print-close, .no-print { display: none !important; }
  nav, footer, .forge-hero, .scripts-hero, .scripts-grid-section, .gold-divider { display: none !important; }
}

/* ═══ RESPONSIVE ═══ */
@media (max-width: 768px) {
  .scripts-grid { grid-template-columns: 1fr; }
  .print-sheet { padding: 32px 24px; }
}
@media (min-width: 769px) and (max-width: 1024px) {
  .scripts-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
</BaseLayout>
