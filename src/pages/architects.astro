<script>
  // Sticky tab active state based on scroll position
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.lineage-tab');
    const ancientSection = document.getElementById('ancient-wisdom');
    const aiSection = document.getElementById('ai-lineage');

    if (!ancientSection || !aiSection || tabs.length === 0) return;

    function updateTabs() {
      const aiTop = aiSection.getBoundingClientRect().top;
      const isAiAge = aiTop <= 120;

      tabs.forEach(tab => {
        const isAiTab = tab.getAttribute('href') === '#ai-lineage';
        tab.classList.toggle('active', isAiAge ? isAiTab : !isAiTab);
      });
    }

    window.addEventListener('scroll', updateTabs, { passive: true });

    // Smooth scroll for tab clicks
    tabs.forEach(tab => {
      tab.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.querySelector(tab.getAttribute('href'));
        if (target) {
          const offset = 68 + 48; // nav + tabs height
          const top = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    });

    // Also handle teaser link smooth scroll
    const teaserLink = document.querySelector('.lineage-teaser-link');
    if (teaserLink) {
      teaserLink.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.querySelector(teaserLink.getAttribute('href'));
        if (target) {
          const offset = 68 + 48;
          const top = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    }
  });
</script>

