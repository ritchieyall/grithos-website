---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Grithos | A Philosophy of Life Built on Grit and Ethos"
  description="Grithos is a philosophy of life built on grit and ethos. Four pillars, twelve tenets, and 365 daily practices for living with moral courage, strength, and purpose."
  ogTitle="Grithos — A Philosophy of Life"
  ogDescription="Four pillars. Twelve tenets. 365 daily practices. A philosophy of life built on grit, ethos, and the moral courage to do right, regardless."
  ogUrl="https://grithos.com"
  canonical="https://grithos.com"
  activePage="home"
>

<style is:inline>
  /* ═══ HERO ═══ */
  .hero {
    padding: 180px 0 100px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%; transform: translateX(-50%);
    width: 900px; height: 900px;
    background: radial-gradient(circle, rgba(201,147,90,.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }
  .hero-logo-wrap {
    position: relative;
    display: inline-block;
    max-width: 420px;
    width: 80%;
    margin-bottom: 20px;
    z-index: 2;
  }
  .hero-logo-wrap::after {
    display: none;
  }
  .hero-logo {
    display: block;
    width: 100%;
    height: auto;
  }
  .hero-subtitle {
    font-family: 'Georgia', serif;
    font-size: clamp(18px, 2.5vw, 24px);
    font-style: italic;
    color: var(--text-secondary);
    margin-bottom: 12px;
  }
  .hero-pronunciation {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: .08em;
    margin-bottom: 48px;
  }
  .hero-divider {
    width: 60px;
    height: 2px;
    background: var(--gold);
    margin: 0 auto 48px;
  }
  .hero-motto {
    font-family: 'Georgia', serif;
    font-size: clamp(20px, 2.8vw, 28px);
    font-weight: 700;
    font-style: italic;
    color: var(--white);
    margin-bottom: 16px;
  }
  .hero-motto-sub {
    font-family: 'Georgia', serif;
    font-size: clamp(15px, 2vw, 18px);
    font-style: italic;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* ═══ SECTION DIVIDER ═══ */
  .section-divider {
    width: 100%;
    height: 1px;
    background: var(--border);
    margin: 0;
  }

  /* ═══ FOUNDATION ═══ */
  .foundation {
    padding: 100px 0;
  }
  .foundation-text {
    font-family: 'Georgia', serif;
    font-size: 18px;
    line-height: 1.9;
    color: var(--text-secondary);
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  /* ═══ CREED ═══ */
  .creed {
    padding: 100px 0;
    text-align: center;
  }
  .creed-text {
    font-family: 'Georgia', serif;
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 700;
    font-style: italic;
    color: var(--white);
    line-height: 1.5;
    max-width: 700px;
    margin: 0 auto;
  }

  /* ═══ PILLARS ═══ */
  .pillars {
    padding: 100px 0 120px;
  }
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    margin-top: 48px;
  }
  .pillar-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 48px 40px;
    transition: border-color .3s, box-shadow .3s;
    text-align: center;
  }
  .pillar-card:hover {
    border-color: var(--gold-border);
    box-shadow: 0 0 40px rgba(201,147,90,.06);
  }
  .pillar-numeral {
    font-family: var(--heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .22em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .pillar-name {
    font-family: var(--heading);
    font-size: 28px;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -.01em;
    margin-bottom: 4px;
  }
  .pillar-tagline {
    font-family: 'Georgia', serif;
    font-size: 14px;
    font-style: italic;
    color: var(--gold-light);
    letter-spacing: .01em;
    margin-bottom: 28px;
  }
  .pillar-divider {
    width: 40px;
    height: 1px;
    background: var(--border);
    margin: 0 auto 28px;
  }
  .pillar-body {
    font-family: var(--body);
    font-size: 15px;
    line-height: 1.85;
    color: var(--text-secondary);
    text-align: left;
  }

  /* ═══ TENETS ═══ */
  .tenets {
    padding: 100px 0 120px;
  }
  .tenets-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    margin-top: 48px;
  }
  .tenets-pillar {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 40px 36px;
    transition: border-color .3s, box-shadow .3s;
  }
  .tenets-pillar:hover {
    border-color: var(--gold-border);
    box-shadow: 0 0 40px rgba(201,147,90,.06);
  }
  .tenets-pillar-label {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }
  .tenets-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tenets-list li {
    border-bottom: 1px solid var(--border);
  }
  .tenets-list li:last-child {
    border-bottom: none;
  }
  .tenets-list li a {
    display: block;
    font-family: var(--heading);
    font-size: 15px;
    font-weight: 700;
    color: var(--white);
    text-decoration: none;
    padding: 12px 0;
    line-height: 1.4;
    transition: color .2s;
  }
  .tenets-list li:last-child a {
    padding-bottom: 0;
  }
  .tenets-list li a:hover {
    color: var(--gold);
  }
  .tenets-list li a span {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .12em;
    color: var(--gold);
    margin-right: 10px;
  }
  .tenets-cta {
    text-align: center;
    margin-top: 48px;
  }
  .tenets-cta a {
    font-family: var(--body);
    font-size: 14px;
    font-weight: 600;
    color: var(--gold);
    text-decoration: none;
    letter-spacing: .02em;
    transition: color .2s;
  }
  .tenets-cta a:hover {
    color: var(--gold-light);
  }
  .tenets-cta a svg {
    width: 14px;
    height: 14px;
    vertical-align: -2px;
    margin-left: 6px;
  }

  /* ═══ TODAY'S PRACTICE ═══ */
  .today-practice {
    padding: 60px 0;
  }
  .today-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: 40px 44px;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: border-color .3s;
  }
  .today-card:hover {
    border-color: var(--gold-border);
  }
  .today-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: .6;
  }
  .today-date {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
  }
  .today-tenet {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 20px;
  }
  .today-text {
    font-family: var(--heading);
    font-size: 22px;
    font-weight: 700;
    color: var(--white);
    line-height: 1.5;
    max-width: 600px;
    margin: 0 auto 24px;
  }
  .today-link {
    font-family: var(--body);
    font-size: 13px;
    font-weight: 600;
    color: var(--gold);
    text-decoration: none;
    letter-spacing: .02em;
    transition: color .2s;
  }
  .today-link:hover {
    color: var(--gold-light);
  }
  .today-link svg {
    width: 13px;
    height: 13px;
    vertical-align: -2px;
    margin-left: 5px;
  }
  .today-forge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--void);
    background: var(--gold);
    padding: 4px 12px;
    border-radius: 4px;
    margin-bottom: 12px;
  }
  @media(max-width:768px) {
    .today-card {
      padding: 32px 24px;
    }
    .today-text {
      font-size: 18px;
    }
  }

  /* ═══ FOUNDER ═══ */
  .founder {
    padding: 80px 0 100px;
    text-align: center;
  }
  .founder-photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
    margin-bottom: 20px;
  }
  .founder-name {
    font-family: 'Georgia', serif;
    font-size: 18px;
    font-style: italic;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }
  .founder-url {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--text-muted);
    letter-spacing: .04em;
  }

  /* ═══ RESPONSIVE ═══ */
  @media(max-width:768px) {
    .pillars-grid,
    .tenets-grid {
      grid-template-columns: 1fr;
    }
    .pillar-card {
      padding: 32px 28px;
    }
    .tenets-pillar {
      padding: 28px 24px;
    }
  }
</style>

<!-- ═══ HERO ═══ -->
<section class="hero">
  <div class="wrap">
    <div class="reveal d1">
      <div class="hero-logo-wrap"><img src="/assets/images/logo.png" alt="Grithos — A philosophy of life built on grit and ethos" class="hero-logo"></div>
      <h1 class="hero-subtitle">A Philosophy of Life</h1>
      <p class="hero-pronunciation">GRITH-os &nbsp;|&nbsp; Practitioner: Grithosian (grith-OH-see-an)</p>
    </div>
    <div class="hero-divider reveal d2"></div>
    <div class="reveal d3">
      <p class="hero-motto">Grit. Ethos. Grithos.</p>
      <p class="hero-motto-sub">From grit and ethos — the moral courage to do right, regardless.</p>
    </div>
  </div>
</section>

<!-- ═══ TODAY'S PRACTICE ═══ -->
<section class="today-practice" id="today">
  <div class="wrap">
    <div class="today-card reveal d1">
      <div id="today-forge-badge" style="display:none;"><span class="today-forge">Forge Day</span></div>
      <div class="today-date" id="today-date"></div>
      <div class="today-tenet" id="today-tenet"></div>
      <p class="today-text" id="today-text"></p>
      <div style="display:flex;align-items:center;justify-content:center;gap:24px;flex-wrap:wrap;">
        <a href="/practice" class="today-link">View full calendar <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg></a>
        <button class="today-link" id="today-share" style="background:none;border:1px solid var(--border);padding:6px 16px;border-radius:6px;cursor:pointer;font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--text-muted);transition:all .2s;" onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--gold)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="13" height="13" style="vertical-align:-2px;margin-right:4px;"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" /></svg>
          Share
        </button>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══ FOUNDATION ═══ -->
<section class="foundation" id="foundation">
  <div class="wrap">
    <div class="reveal d1" style="text-align:center;">
      <div class="sec-label">The Foundation</div>
      <h2 class="sec-title">What Grithos Stands On</h2>
    </div>
    <div class="reveal d2">
      <p class="foundation-text">A rational God exists who authored the bounds underlying all things. God is architect, not manager. The bounds God created are real, consistent, and trustworthy. However you choose to honor God is yours. What Grithos asks is that you also align — with the bounds, with virtue, and with the life you were given.</p>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══ CREED ═══ -->
<section class="creed" id="creed">
  <div class="wrap">
    <div class="reveal d1">
      <div class="sec-label">The Grithos Creed</div>
    </div>
    <div class="reveal d2">
      <p class="creed-text">Do right. Regardless. Own your nature. Live within bounds. Return to the whole.</p>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══ FOUR PILLARS ═══ -->
<section class="pillars" id="pillars">
  <div class="wrap">
    <div class="reveal d1" style="text-align:center;">
      <div class="sec-label">The Philosophy</div>
      <h2 class="sec-title">The Four Pillars</h2>
    </div>

    <div class="pillars-grid">

      <!-- Pillar I -->
      <div class="pillar-card reveal d1">
        <div class="pillar-numeral">Pillar I</div>
        <h3 class="pillar-name">Virtue</h3>
        <div class="pillar-tagline">Do right regardless.</div>
        <div class="pillar-divider"></div>
        <p class="pillar-body">A Grithosian is honest. Not when it is convenient. Not when it is safe. Regardless of the cost. Virtue requires no reward and no recognition. You do right because it is right. That is the only reason a Grithosian needs. Honesty is not a policy. It is a practice — daily, unglamorous, and non-negotiable.</p>
      </div>

      <!-- Pillar II -->
      <div class="pillar-card reveal d2">
        <div class="pillar-numeral">Pillar II</div>
        <h3 class="pillar-name">Apex</h3>
        <div class="pillar-tagline">Own your nature.</div>
        <div class="pillar-divider"></div>
        <p class="pillar-body">Humans are the most capable species on earth. That is not arrogance — it is fact. A Grithosian owns that truth completely and without apology. But apex is not a trophy. It is a weight. With the greatest capability comes the greatest accountability. A Grithosian leads with strength and responsibility in equal measure — protecting those beneath them, never exploiting them. Shrinking from your potential is not humility. It is a betrayal of your nature. What a Grithosian rejects above all else is victim mentality. Not hardship — hardship is real. Not struggle — struggle is human. But the decision to define yourself by what happened to you rather than what you do next. You are apex. Act like it.</p>
      </div>

      <!-- Pillar III -->
      <div class="pillar-card reveal d3">
        <div class="pillar-numeral">Pillar III</div>
        <h3 class="pillar-name">Control</h3>
        <div class="pillar-tagline">Live within bounds.</div>
        <div class="pillar-divider"></div>
        <p class="pillar-body">A Grithosian owns four things completely — their thoughts and attitudes, their decisions and actions, their effort and preparation, and their character and integrity. Everything else belongs to the bounds. Other people's opinions. Outcomes beyond your effort. Illness. Circumstance. The economy. These are not yours to carry. This is not resignation. A Grithosian does not sit still in the face of what they cannot control. They redirect. Immediately. Deliberately. Every ounce of energy that would have been spent fighting the bounds gets turned back toward what is actually theirs to own. God authored the bounds. They are rational. They are consistent. They can be trusted. Live within them.</p>
      </div>

      <!-- Pillar IV -->
      <div class="pillar-card reveal d4">
        <div class="pillar-numeral">Pillar IV</div>
        <h3 class="pillar-name">Death</h3>
        <div class="pillar-tagline">Return to the whole.</div>
        <div class="pillar-divider"></div>
        <p class="pillar-body">A Grithosian does not fear death. It is not an enemy. It is a conclusion — the natural end of a life fully lived. Your body returns to the earth. Your matter rejoins the whole. The universe is permanently and irrevocably different for you having existed in it. Your impact lives on through others. The people you led. The truth you told when it cost you. The times you owned your apex nature and protected those beneath you. That is your legacy in this life — and it matters regardless of what comes next. Grief is not weakness. A Grithosian feels it completely — because only an apex creature capable of deep connection can experience deep loss. But grief is not a residence. Feel it. Honor it. Move. Death is not the opposite of life. It is the completion of it.</p>
      </div>

    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══ TWELVE TENETS ═══ -->
<section class="tenets" id="tenets">
  <div class="wrap">
    <div class="reveal d1" style="text-align:center;">
      <div class="sec-label">The Daily Practice</div>
      <h2 class="sec-title">The Twelve Tenets</h2>
    </div>

    <div class="tenets-grid">

      <!-- Virtue Tenets -->
      <div class="tenets-pillar reveal d1">
        <div class="tenets-pillar-label">From Virtue</div>
        <ul class="tenets-list">
          <li><a href="/tenets#tenet-i"><span>I</span> Tell the Truth. Even When It Costs You.</a></li>
          <li><a href="/tenets#tenet-ii"><span>II</span> Keep Your Word Like Your Life Depends on It.</a></li>
          <li><a href="/tenets#tenet-iii"><span>III</span> Own Your Wins. But Do Right in the Dark.</a></li>
        </ul>
      </div>

      <!-- Apex Tenets -->
      <div class="tenets-pillar reveal d2">
        <div class="tenets-pillar-label">From Apex</div>
        <ul class="tenets-list">
          <li><a href="/tenets#tenet-iv"><span>IV</span> Never Shrink. Never Apologize for Strength.</a></li>
          <li><a href="/tenets#tenet-v"><span>V</span> Protect Those Beneath You.</a></li>
          <li><a href="/tenets#tenet-vi"><span>VI</span> Reject the Victim. Become the Author.</a></li>
        </ul>
      </div>

      <!-- Control Tenets -->
      <div class="tenets-pillar reveal d3">
        <div class="tenets-pillar-label">From Control</div>
        <ul class="tenets-list">
          <li><a href="/tenets#tenet-vii"><span>VII</span> Own Only What Is Yours.</a></li>
          <li><a href="/tenets#tenet-viii"><span>VIII</span> Redirect Immediately.</a></li>
          <li><a href="/tenets#tenet-ix"><span>IX</span> Trust the Bounds.</a></li>
        </ul>
      </div>

      <!-- Death Tenets -->
      <div class="tenets-pillar reveal d4">
        <div class="tenets-pillar-label">From Death</div>
        <ul class="tenets-list">
          <li><a href="/tenets#tenet-x"><span>X</span> Live Like You Will Die. Because You Will.</a></li>
          <li><a href="/tenets#tenet-xi"><span>XI</span> Grieve Fully. Then Move.</a></li>
          <li><a href="/tenets#tenet-xii"><span>XII</span> Build a Legacy That Stands in This Life.</a></li>
        </ul>
      </div>

    </div>

    <div class="tenets-cta reveal d5">
      <a href="/tenets">Read the full tenets <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg></a>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══ FOUNDER ═══ -->
<section class="founder" id="founder">
  <div class="wrap">
    <div class="reveal d1">
      <div class="sec-label">Origin</div>
      <img src="/assets/images/founder.jpeg" alt="Richard Johnson" class="founder-photo" loading="lazy">
      <p class="founder-name">Founded by Richard Johnson</p>
      <p class="founder-subtitle" style="font-family:'Georgia',serif;font-size:16px;font-style:italic;color:var(--white);margin-bottom:8px;max-width:480px;margin-left:auto;margin-right:auto;line-height:1.6;">A man who searched for light — and decided to build one.</p>
      <p class="founder-detail" style="font-family:'Georgia',serif;font-size:14px;color:var(--text-secondary);margin-bottom:16px;max-width:520px;margin-left:auto;margin-right:auto;line-height:1.7;">Grithos was born from a lifetime of hard lessons, ancient wisdom, and the conviction that life should be lived with purpose, not left to chance. That wisdom deserved a home built to last.</p>
      <p class="founder-url">grithos.com</p>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  var MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  var TENETS = [
    'Tenet I — Tell the Truth. Even When It Costs You.',
    'Tenet II — Keep Your Word Like Your Life Depends on It.',
    'Tenet III — Own Your Wins. But Do Right in the Dark.',
    'Tenet IV — Never Shrink. Never Apologize for Strength.',
    'Tenet V — Protect Those Beneath You.',
    'Tenet VI — Reject the Victim. Become the Author.',
    'Tenet VII — Own Only What Is Yours.',
    'Tenet VIII — Redirect Immediately.',
    'Tenet IX — Trust the Bounds.',
    'Tenet X — Live Like You Will Die. Because You Will.',
    'Tenet XI — Grieve Fully. Then Move.',
    'Tenet XII — Build a Legacy That Stands in This Life.'
  ];
  var PRACTICES = {
    0: [
      "Say one thing today exactly as you mean it. No softening.",
      "If someone asks your opinion, give the real one.",
      "Correct a lie you let slide — even an old one.",
      "Tell someone what you actually think of their idea.",
      "Admit something you've been avoiding admitting.",
      "Say \"I don't know\" instead of faking it.",
      "Stop yourself from exaggerating today. Just the facts.",
      "Give feedback someone needs to hear, not what they want to hear.",
      "If you messed up, say so before anyone finds out.",
      "Disagree with someone you usually just nod along with.",
      "Say \"no\" to something you want to say yes to just to be liked.",
      "Be honest with yourself about one thing you've been ignoring.",
