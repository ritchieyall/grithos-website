  var now = new Date();
  var m = now.getMonth();
  var d = now.getDate();
  var dateEl = document.getElementById('today-date');
  var tenetEl = document.getElementById('today-tenet');
  var textEl = document.getElementById('today-text');
  var forgeEl = document.getElementById('today-forge-badge');

  if (dateEl && tenetEl && textEl) {
    var MNAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    dateEl.textContent = MNAMES[m] + ' ' + d + ' — Today\'s Practice';
    tenetEl.textContent = TENETS[m];
    var practice = PRACTICES[m] && PRACTICES[m][d - 1] ? PRACTICES[m][d - 1] : '';
    if (m === 2 && d === 13 && forgeEl) {
      forgeEl.style.display = 'block';
    }
    textEl.textContent = practice;

    // Share button
    var shareBtn = document.getElementById('today-share');
    if (shareBtn && practice) {
      shareBtn.addEventListener('click', function() {
        var canvas = document.createElement('canvas');
        canvas.width = 1080;
        canvas.height = 1080;
        var ctx = canvas.getContext('2d');
        ctx.fillStyle = '#1c2029';
        ctx.fillRect(0, 0, 1080, 1080);
        var grad = ctx.createLinearGradient(0, 0, 1080, 0);
        grad.addColorStop(0, 'transparent');
        grad.addColorStop(0.5, '#c9935a');
        grad.addColorStop(1, 'transparent');
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, 1080, 4);
        ctx.fillStyle = '#c9935a';
        ctx.font = '600 22px sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText((MNAMES[m] + ' ' + d).toUpperCase() + '  —  TODAY\'S PRACTICE', 540, 240);
        ctx.fillStyle = '#70685e';
        ctx.font = '500 16px sans-serif';
        ctx.fillText(TENETS[m].split('—')[0].trim(), 540, 280);
        ctx.fillStyle = '#f5f0eb';
        ctx.font = '700 38px sans-serif';
        var words = practice.split(' ');
        var lines = [];
        var line = '';
        for (var w = 0; w < words.length; w++) {
          var test = line + words[w] + ' ';
          if (ctx.measureText(test).width > 860 && line) {
            lines.push(line.trim());
            line = words[w] + ' ';
          } else {
            line = test;
          }
        }
        lines.push(line.trim());
        var startY = 540 - (lines.length * 54) / 2;
        for (var l = 0; l < lines.length; l++) {
          ctx.fillText(lines[l], 540, startY + l * 54);
        }
        ctx.fillStyle = '#70685e';
        ctx.font = '600 18px sans-serif';
        ctx.fillText('GRITHOS', 540, 940);
        ctx.fillStyle = '#4a443c';
        ctx.font = '400 14px sans-serif';
        ctx.fillText('grithos.com', 540, 970);
        ctx.fillStyle = grad;
        ctx.fillRect(0, 1076, 1080, 4);
        canvas.toBlob(function(blob) {
          if (navigator.share && navigator.canShare) {
            var file = new File([blob], 'grithos-practice.png', { type: 'image/png' });
            var shareData = { files: [file], title: 'Grithos Daily Practice', text: practice };
            if (navigator.canShare(shareData)) {
              navigator.share(shareData).catch(function() {});
              return;
            }
          }
          var a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = 'grithos-practice.png';
          a.click();
          URL.revokeObjectURL(a.href);
        }, 'image/png');
      });
    }
  }
})();
