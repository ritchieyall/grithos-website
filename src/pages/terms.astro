---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Service | Grithos"
  description="Terms of Service for Grithos. The terms governing your use of our website and services."
  ogTitle="Terms of Service — Grithos"
  ogDescription="Terms of Service governing your use of grithos.com and related services."
  ogUrl="https://grithos.com/terms"
  canonical="https://grithos.com/terms"
  activePage="terms"
>

<style is:inline>
  .legal-hero {
    padding: 140px 0 48px;
    text-align: center;
  }
  .legal-hero h1 {
    font-family: var(--heading);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--cream);
    margin-bottom: 12px;
  }
  .legal-hero h1 span { color: var(--gold); }
  .legal-hero p {
    font-size: 17px;
    color: var(--muted);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .legal-section { padding: 0 0 100px; }
  .legal-card {
    background: rgba(255,255,255,.02);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 48px 40px;
    max-width: 780px;
    margin: 0 auto;
  }
  .legal-card .effective {
    font-family: var(--mono, monospace);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 32px;
    display: block;
  }
  .legal-card h2 {
    font-family: var(--heading);
    font-size: 21px;
    font-weight: 700;
    color: var(--cream);
    margin: 40px 0 14px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .legal-card h2:first-of-type {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  .legal-card h3 {
    font-family: var(--heading);
    font-size: 16px;
    font-weight: 600;
    color: var(--gold);
    margin: 20px 0 8px;
  }
  .legal-card p, .legal-card li {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 12px;
  }
  .legal-card ul {
    padding-left: 24px;
    margin-bottom: 16px;
  }
  .legal-card li { margin-bottom: 8px; }
  .legal-card a {
    color: var(--gold);
    text-decoration: none;
    transition: color .2s;
  }
  .legal-card a:hover { text-decoration: underline; }

  @media(max-width:640px) {
    .legal-card { padding: 28px 20px; }
    .legal-hero { padding: 120px 0 32px; }
  }
</style>

<section class="legal-hero">
  <div class="wrap">
    <h1>Terms of <span>Service</span></h1>
    <p>The terms governing your use of our website and services.</p>
  </div>
</section>

