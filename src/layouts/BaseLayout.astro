---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogUrl?: string;
  canonical?: string;
  activePage?: string;
}

const {
  title,
  description = 'Grithos — A philosophy of life built on grit and ethos. Do right. Own your nature. Live within bounds. Return to the whole.',
  ogTitle = '',
  ogDescription = '',
  ogType = 'website',
  ogUrl = '',
  canonical = '',
  activePage = '',
} = Astro.props;

const finalOgTitle = ogTitle || title;
const finalOgDescription = ogDescription || description;
const finalOgUrl = ogUrl || Astro.url.href.replace(/\/$/, '') || 'https://grithos.com';
const finalCanonical = canonical || finalOgUrl;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={finalOgTitle} />
  <meta property="og:description" content={finalOgDescription} />
  <meta property="og:site_name" content="Grithos" />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={finalOgUrl} />
  <link rel="canonical" href={finalCanonical} />
  <meta name="author" content="Richard Johnson">
  <meta name="robots" content="index, follow">
  <meta property="og:image" content="https://grithos.com/assets/images/logo.jpg" />
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={finalOgTitle} />
  <meta name="twitter:description" content={finalOgDescription} />
  <meta name="twitter:image" content="https://grithos.com/assets/images/logo.jpg" />
  <link rel="icon" type="image/jpeg" href="/assets/images/icon.jpg">
  <link rel="manifest" href="/manifest.json">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="apple-touch-icon" href="/assets/images/icon.jpg">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Grithos",
    "url": "https://grithos.com",
    "description": "A philosophy of life built on grit and ethos. Do right. Own your nature. Live within bounds. Return to the whole.",
    "founder": {
      "@type": "Person",
      "name": "Richard Johnson",
      "image": "https://grithos.com/assets/images/founder.jpeg",
      "description": "Founder of Grithos — a philosophy of life built on grit and ethos."
    }
  })} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <slot name="head" />
</head>
<body>
  <Nav activePage={activePage} />
  <main>
    <slot />
  </main>
  <Footer />
  <script is:inline>
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

    // PWA service worker
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(function() {});
    }

    // Dark/Light mode
    (function() {
      var saved = localStorage.getItem('grithos-theme');
      if (saved === 'light') document.documentElement.classList.add('light-mode');
    })();
  </script>
  <!-- Cloudflare Web Analytics -->
  <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "e120758e160d4b2794f2645e58123c82"}'></script>
  <!-- End Cloudflare Web Analytics -->
</body>
</html>
